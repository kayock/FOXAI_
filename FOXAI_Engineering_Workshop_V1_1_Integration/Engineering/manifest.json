{
  "api_version": "foxai.department.v1",
  "id": "engineering",
  "name": "Engineering Department",
  "officer": {
    "name": "Chief Engineer Ada",
    "callsign": "Ada",
    "role": "Chief Engineer"
  },
  "startup_priority": 30,
  "depends_on": [
    "foxkernel",
    "missionbus",
    "vault"
  ],
  "provides": [
    "engineering.health",
    "engineering.route",
    "engineering.search",
    "engineering.diagnose",
    "engineering.implement",
    "engineering.snapshot",
    "engineering.patch.preview",
    "engineering.patch.apply",
    "engineering.validate",
    "engineering.rollback",
    "engineering.receipt",
    "code.format",
    "code.lint",
    "code.typecheck",
    "architecture.inspect",
    "security.audit",
    "sbom.generate"
  ],
  "services": [
    "Engineering Workshop",
    "Repair Bay",
    "Diagnostics",
    "Build Verification",
    "Code Review",
    "Architecture Inspection",
    "Security Inspection"
  ],
  "tools": [
    {
      "id": "python-stdlib-workshop",
      "import": "Departments.Engineering.workshop",
      "purpose": "Controlled snapshot, exact patch, validation, rollback, and evidence receipts"
    },
    {
      "id": "ruff",
      "import": "ruff",
      "purpose": "Fast linting and formatting checks",
      "optional": true
    },
    {
      "id": "black",
      "import": "black",
      "purpose": "Python formatting",
      "optional": true
    },
    {
      "id": "mypy",
      "import": "mypy",
      "purpose": "Static type checking",
      "optional": true
    },
    {
      "id": "pydeps",
      "import": "pydeps",
      "purpose": "Import graph visualization",
      "optional": true
    },
    {
      "id": "import-linter",
      "import": "importlinter",
      "purpose": "Architecture boundary enforcement",
      "optional": true
    },
    {
      "id": "grimp",
      "import": "grimp",
      "purpose": "Import graph analysis",
      "optional": true
    },
    {
      "id": "pip-audit",
      "import": "pip_audit",
      "purpose": "Dependency vulnerability scanning",
      "optional": true
    },
    {
      "id": "cyclonedx-bom",
      "import": "cyclonedx_py",
      "purpose": "SBOM generation",
      "optional": true
    }
  ],
  "health_check": "Departments.Engineering.health:health",
  "entrypoints": {
    "workshop_cli": "Departments.Engineering.cli:main"
  },
  "ui": {
    "panel": "engineering",
    "accent": "orange",
    "mode": "read_only_until_exact_plan_approval"
  },
  "version": "1.0.0",
  "type": "department",
  "description": "Engineering Department with a controlled, evidence-backed implementation workshop.",
  "enabled": true
}
