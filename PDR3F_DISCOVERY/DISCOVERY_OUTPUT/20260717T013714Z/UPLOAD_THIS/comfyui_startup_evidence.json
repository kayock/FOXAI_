    "text": "<section id=creative class=page><div class=hero><h2>Creative Studio</h2><p>ComfyUI remains the image engine.</p></div><div class=grid><div class=card><h3>ComfyUI</h3><button onclick=\"api('/api/launch/comfy')\">Launch</button><button onclick=\"api('/api/open-url/comfy')\">Open</button></div><div class=card><h3>Gallery</h3><button onclick=\"api('/api/open/comfy_output')\">Open Output</button></div></div></section>"
