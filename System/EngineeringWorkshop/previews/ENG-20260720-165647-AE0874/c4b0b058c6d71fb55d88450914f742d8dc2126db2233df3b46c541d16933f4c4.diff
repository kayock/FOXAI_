+        return []
+    conn = connect_library_state_db(paths)
+    try:
+        rows = conn.execute(
+            "SELECT id,ebook_id,spine_index,fragment,scroll_ratio,label,created_at FROM epub_bookmarks WHERE source_sha256=? ORDER BY created_at DESC,id DESC",
