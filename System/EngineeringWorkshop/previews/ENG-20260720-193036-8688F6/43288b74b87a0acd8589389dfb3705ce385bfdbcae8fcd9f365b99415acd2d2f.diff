+def _common_nonempty(values) -> str:
+    counts: dict[str, tuple[int, str]] = {}
+    for raw in values:
+        text = normalize_text(raw, 500)
+        if not text:
+            continue
+        key = text.casefold()
+        count, _ = counts.get(key, (0, text))
+        counts[key] = (count + 1, text)
+    if not counts:
+        return ""
+    return max(counts.values(), key=lambda item: (item[0], len(item[1])))[1]
