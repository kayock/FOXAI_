+        now_epoch = time.time()
+        active = bool(row and row["owner_token"] and now_epoch - float(row["heartbeat_epoch"] or 0) < _PLAYBACK_LEASE_SECONDS)
+        if active and row["owner_token"] != token:
+            return {
