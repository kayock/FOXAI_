+        if focus_key in {'light cleanup','preserve voice with minimal changes'}:
+            minimum=1
+        elif focus_key=='deep polish — preserve story':
+            minimum=6
+        else:
+            minimum=3
+        return bool(
+            int(metrics.get('changed_words') or 0)>=minimum
+            or float(metrics.get('similarity') or 1.0)<=0.992
+        )
