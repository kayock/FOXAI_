+def build_coverage(data: dict[str, Any], top: list[dict[str, Any]], launchers: dict[str, Any], runtimes: dict[str, Any], reusable: dict[str, Any], storage: dict[str, Any], missions: dict[str, Any]) -> dict[str, Any]:
+    return {
+        "schema": NORMALIZER_SCHEMA,
+        "source_audit_result": data["AUDIT_RECEIPT.json"].get("result"),
+        "source_mission_id": data["AUDIT_RECEIPT.json"].get("mission_id"),
