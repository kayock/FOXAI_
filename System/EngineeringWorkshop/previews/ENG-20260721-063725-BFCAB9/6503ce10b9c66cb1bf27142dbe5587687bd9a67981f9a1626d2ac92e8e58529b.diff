+def split_chain(command: str) -> list[str]:
+    result: list[str] = []
+    current: list[str] = []
+    quote: str | None = None
+    index = 0
+    while index < len(command):
+        char = command[index]
+        if char in {'"', "'"}:
+            if quote == char:
+                quote = None
+            elif quote is None:
+                quote = char
+            current.append(char)
+            index += 1
+            continue
+        if quote is None and command[index:index + 2] in {"&&", "||"}:
+            segment = "".join(current).strip()
+            if segment:
+                result.append(segment)
+            current = []
+            index += 2
+            continue
+        current.append(char)
+        index += 1
+    segment = "".join(current).strip()
+    if segment:
+        result.append(segment)
+    return result
+
