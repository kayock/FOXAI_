+def build_bridge_from_capture(project_root: Path, mission_id: str, bundle: dict[str, Any]) -> tuple[dict[str, Any], dict[str, bytes]]:
+    source_receipt = bundle["receipt"]
+    prior_code = bundle["objects"]["STATIC_CODE_INDEX.json"]
+    prior_launcher = bundle["objects"]["STATIC_LAUNCHER_INDEX.json"]
+    prior_reference = bundle["objects"]["STATIC_REFERENCE_INDEX.json"]
+    known_good = bundle["objects"]["KNOWN_GOOD_COMPARISON.json"]
+
+    code_files = sorted(prior_code.get("files", []), key=lambda item: str(item.get("relative_path", "")).casefold())
+    line_records: list[dict[str, Any]] = []
+    reference_coverage: list[dict[str, Any]] = []
+    current_hashes: list[dict[str, Any]] = []
+    for file_record in code_files:
+        relative = str(file_record.get("relative_path", ""))
+        path = project_root / Path(relative)
+        current_hashes.append(current_hash_status(file_record, project_root))
+        records, coverage = collect_reference_lines(path, relative, str(file_record.get("language", "text")))
+        line_records.extend(records)
+        reference_coverage.append(coverage)
+
+    shard_files, shard_catalog = create_reference_shards(line_records)
+    launcher_records: list[dict[str, Any]] = []
+    launcher_errors = Counter()
+    for prior in sorted(prior_launcher.get("records", []), key=lambda item: str(item.get("relative_path", "")).casefold()):
+        raw_path = prior.get("path")
+        path = Path(raw_path) if raw_path else project_root / Path(prior.get("relative_path", ""))
+        classification = prior.get("path_classification", {})
+        if not path_is_file(path) or path_is_symlink(path):
+            launcher_records.append({
+                "schema": BRIDGE_SCHEMA, "path": norm_win(path), "relative_path": prior.get("relative_path"),
+                "path_classification": classification, "parse_status": "missing_or_unreadable", "launcher_executed": False,
+                "settings": [], "labels": [], "gotos": [], "working_directories": [], "existence_checks": [],
+                "diagnostics": [], "file_operations": [], "control_flow": [], "called_launchers": [], "edges": [],
+                "interpreter_invocations": [], "urls": [], "os_shell_references": [], "external_commands": [],
+                "unresolved_references": [], "ports": [], "environment_references": [],
+                "confirmed_active_or_executed_targets": 0,
+            })
+            launcher_errors["missing_or_unreadable"] += 1
+            continue
+        try:
+            launcher_records.append(parse_launcher(path, project_root, classification))
+        except (PermissionError, OSError, ValueError) as exc:
+            launcher_records.append({
+                "schema": BRIDGE_SCHEMA, "path": norm_win(path), "relative_path": prior.get("relative_path"),
+                "path_classification": classification, "parse_status": "read_error", "error": f"{type(exc).__name__}:{exc}",
+                "launcher_executed": False, "settings": [], "labels": [], "gotos": [], "working_directories": [],
+                "existence_checks": [], "diagnostics": [], "file_operations": [], "control_flow": [],
+                "called_launchers": [], "edges": [], "interpreter_invocations": [], "urls": [],
+                "os_shell_references": [], "external_commands": [], "unresolved_references": [], "ports": [],
+                "environment_references": [], "confirmed_active_or_executed_targets": 0,
+            })
+            launcher_errors["read_error"] += 1
+
+    metrics = launcher_false_edge_metrics(launcher_records)
+    launcher_index = {
+        "schema": BRIDGE_SCHEMA, "mission_id": mission_id, "project_root": norm_win(project_root),
+        "static_only": True, "immutable_input_capture_used": True, "launchers_executed": False,
+        "source_launcher_record_count": prior_launcher.get("record_count"), "records": launcher_records,
+        "record_count": len(launcher_records),
+        "edge_count": sum(len(item.get("edges", [])) for item in launcher_records),
+        "interpreter_invocation_count": sum(len(item.get("interpreter_invocations", [])) for item in launcher_records),
+        "url_reference_count": sum(len(item.get("urls", [])) for item in launcher_records),
+        "false_edge_metrics": metrics, "confirmed_active_or_executed_targets": 0,
+    }
+    reference_catalog = {
+        "schema": BRIDGE_SCHEMA, "mission_id": mission_id, "immutable_input_capture_used": True,
+        "global_line_record_ceiling_used": False, "per_file_line_limit": MAX_REFERENCE_LINES_PER_FILE,
+        "line_record_count": len(line_records), "source_file_coverage_count": len(reference_coverage),
+        "source_file_coverage": reference_coverage, "shard_count": len(shard_catalog), "shards": shard_catalog,
+        "symbol_index": prior_reference.get("symbol_index", {}), "import_index": prior_reference.get("import_index", {}),
+        "setting_index": prior_reference.get("setting_index", {}), "reference_index": prior_reference.get("reference_index", {}),
+        "prior_v1a2_line_record_count": prior_reference.get("line_record_count"),
+        "prior_v1a2_global_cap_reached": prior_reference.get("line_record_cap_reached"),
+    }
+    coverage = {
+        "schema": BRIDGE_SCHEMA, "mission_id": mission_id,
+        "source_v1a2_mission_id": source_receipt.get("mission_id"), "source_files_from_v1a2": len(code_files),
+        "current_source_hash_status": dict(Counter(item["status"] for item in current_hashes)),
+        "current_source_hash_records": current_hashes, "reference_line_records": len(line_records),
+        "reference_shards": len(shard_catalog),
+        "reference_files_complete": sum(item.get("status") == "complete" for item in reference_coverage),
+        "reference_files_per_file_limit_reached": sum(item.get("status") == "per_file_line_limit_reached" for item in reference_coverage),
+        "reference_files_missing_or_unreadable": sum(item.get("status") in {"missing_or_unreadable", "read_error"} for item in reference_coverage),
+        "global_line_record_ceiling_used": False, "launcher_records_processed": len(launcher_records),
+        "launcher_parse_status": dict(Counter(item.get("parse_status", "unknown") for item in launcher_records)),
+        "launcher_errors": dict(sorted(launcher_errors.items())), "false_edge_metrics": metrics,
+        "complete_areas": [
+            "Immutable single-read inputs feed both internal deterministic builds",
+            "Refined static BAT/CMD parsing separates launchers, interpreters, scripts, URLs, shell references, checks, diagnostics, file operations, and control flow",
+            "Reference-line evidence is deterministically sharded with per-file coverage",
+            "V1A-2 symbol, import, setting, reference, code, source-hash, and known-good evidence is provenance-checked",
+        ],
+        "partial_areas": [
+            "Per-file reference lines remain bounded to 5000 nonblank noncomment lines and report omissions",
+            "Dynamic delayed expansion, arbitrary batch subroutines, registry-derived paths, and runtime shell behavior remain unverified",
+            "Live drift is reported separately and is not treated as parser nondeterminism",
+        ],
+        "not_collected_areas": [
+            "Runtime execution, sys.path, imports at runtime, processes, services, open ports, scheduled tasks, event logs, signatures, shortcuts, models, and repairs",
+        ],
+        "network_used": False, "packages_installed": False, "foxai_source_imported_or_executed": False,
+        "launchers_executed": False, "python_interpreters_probed": False, "models_loaded": False,
+    }
+    receipt_seed = {
+        "schema": BRIDGE_SCHEMA, "mission_id": mission_id, "result": "immutable_input_determinism_repair_complete",
+        "source_v1a2_mission_id": source_receipt.get("mission_id"), "source_v1a2_result": source_receipt.get("result"),
+        "source_v1a2_outputs_verified": True, "immutable_input_capture_used": True,
+        "network_used": False, "packages_installed": False, "foxai_source_imported_or_executed": False,
+        "launchers_executed": False, "python_interpreters_probed": False, "models_loaded": False,
+        "existing_foxai_source_modified": False, "known_good_candidates_all_match": known_good.get("all_match"),
+        "shell_builtin_launch_edge_count": metrics["shell_builtin_launch_edge_count"],
+        "url_as_filesystem_edge_count": metrics["url_as_filesystem_edge_count"],
+        "comment_launch_edge_count": metrics["comment_launch_edge_count"],
