+def parse_command_flags(command: str) -> list[str]:
+    flags = []
+    tokens = re.findall(r'''"[^"]*"|'[^']*'|\S+''', command or "")
+    for token in tokens:
+        clean = token.strip('"\'')
+        if re.match(r"^-[A-Za-z](?:[A-Za-z]*)?$", clean) or re.match(r"^-X\S+$", clean):
+            flags.append(clean)
+    return flags
