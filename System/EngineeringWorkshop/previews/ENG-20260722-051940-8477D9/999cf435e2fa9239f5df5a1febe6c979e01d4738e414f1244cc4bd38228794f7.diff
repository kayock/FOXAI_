+
+def _write_canonical(path: Path, value: Any) -> dict[str, Any]:
+    data = canonical_bytes(sanitize(value))
+    if b"\r" in data:
+        raise AssertionError("canonical JSON contains carriage return")
+    path.write_bytes(data)
+    return {"name": path.name, "size_bytes": len(data), "sha256": sha256_bytes(data)}
+
+
+def _privacy_assertions(payloads: Iterable[bytes]) -> None:
+    materialized = list(payloads)
+    joined = b"\n".join(materialized)
+    lower = joined.lower()
+    for marker in PROFILE_MARKERS:
+        encoded = marker.encode("utf-8", errors="ignore").lower()
+        if encoded and encoded in lower:
+            raise AssertionError("profile marker leaked into evidence")
+
+    parsed: list[Any] = []
+    for payload in materialized:
+        try:
+            parsed.append(json.loads(payload.decode("utf-8")))
+        except Exception as exc:
+            raise AssertionError(f"privacy validation requires canonical JSON evidence: {exc}") from exc
+
+    exclusion_key = "sensitive_identifiers_excluded"
+    allowed_exclusion_labels = {
+        "product_keys",
+        "device_serial_numbers",
+        "motherboard_uuid",
+        "mac_addresses",
+        "credentials",
+        "account_tokens",
+    }
+    forbidden_identifier_keys = {
+        "motherboard_uuid",
+        "baseboard_uuid",
+        "board_uuid",
+        "system_uuid",
+        "hardware_uuid",
+        "device_uuid",
+        "product_key",
+        "mac_address",
+    }
+
+    def validate_tree(value: Any, path: tuple[str, ...] = ()) -> None:
+        if isinstance(value, dict):
+            for raw_key, item in value.items():
+                key = str(raw_key).strip().lower()
+                if key == exclusion_key:
+                    if not isinstance(item, list) or not all(isinstance(label, str) for label in item):
+                        raise AssertionError("sensitive_identifiers_excluded must be a list of labels")
+                    normalized_labels = [label.strip().lower() for label in item]
+                    if len(normalized_labels) != len(set(normalized_labels)):
+                        raise AssertionError("duplicate sensitive-identifiers exclusion label")
+                    if not set(normalized_labels).issubset(allowed_exclusion_labels):
+                        raise AssertionError("unknown sensitive-identifiers exclusion label")
+                    continue
+                if key in forbidden_identifier_keys or ("motherboard" in key and "uuid" in key):
+                    raise AssertionError(f"forbidden sensitive identifier field: {raw_key!r}")
+                validate_tree(item, path + (str(raw_key),))
+        elif isinstance(value, list):
+            for index, item in enumerate(value):
+                validate_tree(item, path + (str(index),))
+        elif isinstance(value, str):
+            if value.strip().lower() == "motherboard_uuid":
+                raise AssertionError("motherboard_uuid label occurred outside sensitive_identifiers_excluded")
+
+    def strip_exclusion_declarations(value: Any) -> Any:
+        if isinstance(value, dict):
+            return {
+                key: strip_exclusion_declarations(item)
+                for key, item in value.items()
+                if str(key).strip().lower() != exclusion_key
+            }
+        if isinstance(value, list):
+            return [strip_exclusion_declarations(item) for item in value]
+        return value
+
+    for document in parsed:
+        validate_tree(document)
+
+    scrubbed = b"\n".join(canonical_bytes(strip_exclusion_declarations(document)) for document in parsed).lower()
+    forbidden_tokens = (
+        b'"command_line"',
+        b'"environment_values"',
+        b'"product_key"',
+        b'"mac_address"',
+        b'"motherboard_uuid"',
+    )
+    for token in forbidden_tokens:
+        if token in scrubbed:
+            raise AssertionError(f"forbidden evidence token: {token!r}")
+
+
+def collect(mission_id: str, output_dir: Path) -> dict[str, Any]:
+    collected_at = utc_now()
+    audit = AuditLog(collected_at)
+    output_dir = Path(output_dir)
+    output_dir.mkdir(parents=True, exist_ok=False)
+
+    host = collect_host(collected_at, audit)
+    drives = collect_drives(collected_at, audit)
+    workspace = collect_workspace(collected_at, audit, drives)
+    python_output = collect_python(collected_at, audit)
+    processes = collect_processes(collected_at, audit)
+    services_listeners = collect_services_startup_listeners(collected_at, audit, processes)
+    observations = collect_observations(collected_at, host, drives, python_output, processes, services_listeners)
+
+    payload_map = {
+        "HOST_AND_WINDOWS_BASELINE.json": host,
+        "ACTIVE_DRIVE_BASELINE.json": drives,
+        "FOXAI_ACTIVE_WORKSPACE_BASELINE.json": workspace,
+        "PYTHON_RUNTIME_INVENTORY.json": python_output,
