+    assert rows[8]["evidence_loaded"] is False
+    assert rows[9]["evidence_loaded"] is False
+    return {
+        "fixture_count": len(rows),
+        "resource_answer_count": sum(row["actual_status"] == "answered" for row in rows),
+        "not_applicable_count": sum(row["actual_status"] == "not_applicable" for row in rows),
+        "slash_bypass_count": sum(row["actual_status"] == "bypass" for row in rows),
+        "rows": rows,
+    }
