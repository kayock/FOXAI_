+def answer_question(message: Any, request_id: str | None = None, source_dir: Path | None = None) -> dict[str, Any]:
+    normalized = _normalized_message(message)
+    rid = request_id or stable_id("RESOURCE-REQ", normalized.casefold())
+    classification = classify_question(message)
+    if classification["status"] == "bypass":
+        return _non_answer_result("bypass", "Slash commands bypass the resource provider before evidence loading.", classification, rid)
+    if classification["status"] == "not_applicable":
+        return _non_answer_result("not_applicable", "The message is outside the bounded resource-evidence catalog.", classification, rid)
+    loaded = load_authoritative_evidence(source_dir)
+    packet = _answer_from_index(classification["matched_category"], _evidence_index(loaded), rid)
+    return {
+        "schema": f"{SCHEMA_PREFIX}.provider_result.v1",
+        "request_id": rid,
+        "status": "answered",
+        "provider": PROVIDER_NAME,
+        "answer_text": packet["answer_text"],
+        "matched_category": packet["matched_category"],
+        "confidence_basis": packet["confidence_basis"],
+        "source_mission": packet["source_mission"],
+        "source_files": packet["source_files"],
+        "source_record_ids": packet["source_record_ids"],
+        "observed_values": packet["observed_values"],
+        "derived_values": packet["derived_values"],
+        "limitations": packet["limitations"],
+        "current_state_claimed": False,
+        "live_scan_performed": False,
+        "evidence_loaded": True,
+        "routing_reason": classification["reason"],
+        "answer_packet": packet,
+    }
+
