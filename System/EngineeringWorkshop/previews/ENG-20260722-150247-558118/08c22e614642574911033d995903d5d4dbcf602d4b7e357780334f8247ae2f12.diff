+def load_authoritative_evidence(source_dir: Path | None = None) -> dict[str, Any]:
+    root = Path(source_dir) if source_dir is not None else Path(_SOURCE_DIR)
+    raw = _read_verified_sources(root)
+    receipt = json.loads(raw["BASELINE_COMPARISON_RECEIPT.json"].decode("utf-8"))
+    if receipt.get("status") != "compared_and_verified":
+        raise ValueError("v1b1c_receipt_not_compared_and_verified")
+    if receipt.get("authoritative_inputs_verified") is not True or receipt.get("output_count") != 5:
+        raise ValueError("v1b1c_receipt_relationship_invalid")
+    comparison = json.loads(raw["RESOURCE_BASELINE_COMPARISON.json"].decode("utf-8"))
+    attribution = json.loads(raw["FOXAI_COMPONENT_RESOURCE_ATTRIBUTION.json"].decode("utf-8"))
+    headroom = json.loads(raw["CAPACITY_HEADROOM_OBSERVATIONS.json"].decode("utf-8"))
+    _AUDIT["evidence_loads"] += 1
+    return {
+        "source_dir": str(root),
+        "raw": raw,
+        "comparison": comparison,
+        "attribution": attribution,
+        "headroom": headroom,
+        "report_text": raw["BASELINE_COMPARISON_REPORT.md"].decode("utf-8"),
+        "receipt": receipt,
+    }
