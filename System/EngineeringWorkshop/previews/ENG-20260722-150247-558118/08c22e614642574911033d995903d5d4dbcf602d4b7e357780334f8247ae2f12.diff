+    assert rows[2]["answer_packet"]["observed_values"]["available_physical_memory_bytes"] == 8379232256
+    assert rows[3]["answer_packet"]["observed_values"]["loaded_capture_page_file_current_usage_mib"] == 693
+    assert rows[3]["answer_packet"]["observed_values"]["historical_peak_usage_mib"] == 8191
+    assert rows[4]["answer_packet"]["observed_values"]["idle_comfyui_working_set_bytes"] == 567324672
+    assert "do not prove capacity during active image generation" in rows[5]["answer_packet"]["answer_text"].casefold()
