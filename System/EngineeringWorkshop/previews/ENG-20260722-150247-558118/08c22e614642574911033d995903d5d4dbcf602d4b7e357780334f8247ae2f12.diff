+        {"fixture_id": "FIXTURE-05", "question": "Does idle ComfyUI use most of the memory?", "expected_status": "answered", "expected_category": "idle_comfyui_working_set"},
+        {"fixture_id": "FIXTURE-06", "question": "Can this prove I can generate images while the 30B model is loaded?", "expected_status": "answered", "expected_category": "active_image_generation_capacity_limitation"},
+        {"fixture_id": "FIXTURE-07", "question": "How many more FOXAI processes were present in the loaded capture?", "expected_status": "answered", "expected_category": "foxai_process_count_delta"},
+        {"fixture_id": "FIXTURE-08", "question": "What ports were present in the minimal and loaded captures?", "expected_status": "answered", "expected_category": "listener_presence_captured_states"},
+        {"fixture_id": "FIXTURE-09", "question": "Tell me a joke.", "expected_status": "not_applicable", "expected_category": None},
