+def _read_verified_sources(source_dir: Path) -> dict[str, bytes]:
+    _AUDIT["source_verify_calls"] += 1
+    result: dict[str, bytes] = {}
+    for name in sorted(SOURCE_HASHES):
+        path = source_dir / name
+        if not path.is_file():
+            raise FileNotFoundError(f"authoritative_resource_evidence_missing:{name}")
+        data = path.read_bytes()
+        _AUDIT["source_file_reads"] += 1
+        actual = sha256_bytes(data)
+        if actual != SOURCE_HASHES[name]:
+            raise ValueError(f"authoritative_resource_evidence_hash_mismatch:{name}")
+        result[name] = data
+    return result
+
