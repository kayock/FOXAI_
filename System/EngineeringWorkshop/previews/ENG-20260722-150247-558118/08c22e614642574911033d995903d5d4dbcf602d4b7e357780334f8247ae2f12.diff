+def classify_question(message: Any) -> dict[str, Any]:
+    """Classify without loading evidence. Slash-command bypass is first."""
+    _AUDIT["classify_calls"] += 1
+    normalized = _normalized_message(message)
+    stripped = normalized.lstrip()
+    if stripped.startswith("/"):
+        return {
+            "status": "bypass",
+            "matched_category": "slash_command_bypass",
+            "evidence_required": False,
+            "reason": "first_non_whitespace_character_is_slash",
+        }
+    if not normalized:
+        return {
+            "status": "not_applicable",
+            "matched_category": None,
+            "evidence_required": False,
+            "reason": "empty_message",
+        }
+
+    lower = normalized.casefold()
+    # The explicit page-file fixture is answered from captured evidence while
+    # making no current-live claim. Other direct live-state questions pass on.
+    page_file_question = "page file" in lower or "pagefile" in lower
