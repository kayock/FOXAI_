+def run_fixture_suite(loaded: dict[str, Any]) -> dict[str, Any]:
+    index = _evidence_index(loaded)
+    rows = []
+    for spec in _fixture_specs():
+        classification = classify_question(spec["question"])
+        rid = spec["fixture_id"]
+        before = audit_snapshot()
+        if classification["status"] == "resource_question":
+            packet = _answer_from_index(classification["matched_category"], index, rid)
+            status = packet["status"]
+            category = packet["matched_category"]
+            evidence_loaded = True
+            answer_packet = packet
+        elif classification["status"] == "bypass":
+            status = "bypass"
+            category = classification["matched_category"]
+            evidence_loaded = False
+            answer_packet = None
+        else:
+            status = "not_applicable"
+            category = None
+            evidence_loaded = False
+            answer_packet = None
+        after = audit_snapshot()
+        assert status == spec["expected_status"], (spec, status)
+        assert category == spec["expected_category"], (spec, category)
+        if answer_packet is not None:
+            assert answer_packet["current_state_claimed"] is False
+            assert answer_packet["live_scan_performed"] is False
+            assert answer_packet["source_mission"] == SOURCE_MISSION
+            assert answer_packet["source_files"]
+            assert answer_packet["source_record_ids"]
+        rows.append({
+            **spec,
+            "actual_status": status,
+            "actual_category": category,
+            "evidence_loaded": evidence_loaded,
+            "source_read_delta": after["source_file_reads"] - before["source_file_reads"],
+            "answer_packet": answer_packet,
+        })
+    # Exact grounded fixture assertions.
+    assert rows[0]["answer_packet"]["observed_values"]["physical_memory_in_use_bytes"] == 42833985536
