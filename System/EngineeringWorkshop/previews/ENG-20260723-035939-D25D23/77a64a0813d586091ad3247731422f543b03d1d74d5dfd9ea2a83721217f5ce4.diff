+def _safe_relative(project_root: Path, relative: str) -> Path:
+    normalized = relative.replace("\\", "/")
+    pure = PurePosixPath(normalized)
+    if pure.is_absolute() or ".." in pure.parts:
+        raise ContractError(f"Unsafe relative path: {relative}")
+    path = project_root / Path(*pure.parts)
+    try:
+        path.resolve().relative_to(project_root.resolve())
+    except Exception as exc:
+        raise ContractError(f"Path escapes project root: {relative}") from exc
+    return path
+
+
+def export_capsule(request_path: Path, output_path: Path, bridge_root: Path) -> dict[str, Any]:
+    request = _json_load(request_path)
+    if not isinstance(request, Mapping):
+        raise ContractError("Capsule request must be one JSON object.")
+    project_root = Path(str(request.get("project_root") or ""))
+    files = request.get("files")
+    if not isinstance(files, list) or not files:
+        raise ContractError("Capsule request files must be a non-empty list.")
+
+    records: list[dict[str, Any]] = []
+    for item in files:
+        if not isinstance(item, Mapping):
+            raise ContractError("Each capsule file entry must be an object.")
+        relative = str(item.get("path") or "")
+        path = _safe_relative(project_root, relative)
+        record = _file_record(project_root, relative)
+        if not path.is_file():
+            records.append(record)
+            continue
+        text = path.read_text(encoding="utf-8")
+        ranges = item.get("line_ranges") or []
+        excerpts: list[dict[str, Any]] = []
+        lines = text.splitlines()
+        if ranges:
+            for pair in ranges:
+                if (
+                    not isinstance(pair, list)
+                    or len(pair) != 2
+                    or not all(isinstance(value, int) for value in pair)
+                ):
+                    raise ContractError(f"Invalid line range for {relative}: {pair!r}")
+                start, end = pair
+                if start < 1 or end < start:
+                    raise ContractError(f"Invalid line range for {relative}: {pair!r}")
+                excerpts.append({
+                    "start_line": start,
+                    "end_line": min(end, len(lines)),
+                    "lines": [
+                        {"line": number, "text": lines[number - 1]}
+                        for number in range(start, min(end, len(lines)) + 1)
+                    ],
+                })
+        record["excerpts"] = excerpts
+        records.append(record)
+
+    capsule: dict[str, Any] = {
+        "schema": "foxai.engineering.reference_capsule.v1",
+        "capsule_id": request.get("capsule_id"),
+        "project_root": str(project_root),
+        "fixed_file_list_only": True,
+        "filesystem_walk_performed": False,
+        "files": records,
+    }
+    if request.get("include_plan_schema"):
+        capsule["plan_schema"] = _json_load(bridge_root / PLAN_SCHEMA_NAME)
+    if request.get("include_command_grammar"):
+        capsule["command_grammar"] = _json_load(bridge_root / COMMAND_GRAMMAR_NAME)
+
+    capsule_bytes = (
+        json.dumps(capsule, indent=2, sort_keys=True, ensure_ascii=False) + "\n"
+    ).encode("utf-8")
+    output_path.parent.mkdir(parents=True, exist_ok=True)
+    output_path.write_bytes(capsule_bytes)
+    receipt = {
+        "schema": "foxai.engineering.reference_capsule.receipt.v1",
+        "capsule_path": str(output_path),
+        "capsule_sha256": _sha256(capsule_bytes),
+        "file_count": len(records),
+        "fixed_file_list_only": True,
+        "filesystem_walk_performed": False,
+        "network_used": False,
+        "project_modified": False,
+    }
+    _json_write(output_path.with_suffix(output_path.suffix + ".receipt.json"), receipt)
+    return receipt
+
+
+def explain_receipt(path: Path) -> dict[str, Any]:
+    receipt = _json_load(path)
+    validations = receipt.get("validations") if isinstance(receipt, Mapping) else None
+    failed = []
+    if isinstance(validations, list):
+        for index, row in enumerate(validations):
+            if not isinstance(row, Mapping):
+                continue
+            return_code = row.get("returncode")
+            if return_code not in (None, 0):
+                failed.append({
+                    "index": index,
+                    "name": row.get("name"),
+                    "returncode": return_code,
+                    "stdout": row.get("stdout"),
+                    "stderr": row.get("stderr"),
+                    "timed_out": row.get("timed_out"),
+                    "argv": row.get("argv"),
+                    "cwd": row.get("cwd"),
+                })
+    return {
+        "schema": "foxai.engineering.contract_bridge.failure_explanation.v1",
+        "receipt_path": str(path),
+        "mission_id": receipt.get("mission_id") if isinstance(receipt, Mapping) else None,
+        "result": receipt.get("result") if isinstance(receipt, Mapping) else None,
+        "rolled_back": receipt.get("rolled_back") if isinstance(receipt, Mapping) else None,
+        "failure": receipt.get("failure") if isinstance(receipt, Mapping) else None,
+        "failed_validation_count": len(failed),
+        "failed_validations": failed,
+    }
+
