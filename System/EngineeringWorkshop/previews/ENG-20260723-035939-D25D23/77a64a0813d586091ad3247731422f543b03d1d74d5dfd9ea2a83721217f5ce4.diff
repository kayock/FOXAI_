+from __future__ import annotations
+
+import argparse
+import ast
+import builtins
+import hashlib
+import json
+from pathlib import Path, PurePosixPath
+import re
+import shutil
+import subprocess
+import sys
+import tempfile
+import zipfile
+from typing import Any, Iterable, Mapping, Optional
+
+
+BRIDGE_ID = "engineering_workshop_contract_reference_bridge_v1"
+BRIDGE_VERSION = "1.0.0"
+PLAN_SCHEMA_NAME = "WORKSHOP_PLAN_SCHEMA_V1.json"
+COMMAND_GRAMMAR_NAME = "WORKSHOP_COMMAND_GRAMMAR_V1.json"
+FIXTURES_NAME = "CONTRACT_BRIDGE_FIXTURES_V1.json"
+
+FIXED_CURRENT_SOURCE_CANDIDATES = (
+    "core/engineering_workshop_bridge.py",
+    "core/engineer_agent.py",
+    "Departments/Engineering/patch_engine.py",
+    "Departments/Engineering/workshop.py",
+    "Departments/Engineering/models.py",
+    "Departments/Engineering/validator.py",
+    "Departments/Engineering/mission_router.py",
+    "Departments/Engineering/mission_state.py",
+    "System/AgentFoxTechnicalCore/Reference/TECHNICAL_CORE_REFERENCE_MANIFEST.json",
+    "System/AgentFoxTechnicalCore/Reference/TECHNICAL_CORE_REFERENCE_GUIDE.md",
+)
+
+AUTHORITATIVE_REFERENCE_HASHES = {
+    "System/AgentFoxTechnicalCore/Reference/TECHNICAL_CORE_REFERENCE_MANIFEST.json":
+        "459b1d16af76af323fdd5037af7f044c7accf19db7e40652c3c7a6bb0d883737",
+    "System/AgentFoxTechnicalCore/Reference/TECHNICAL_CORE_REFERENCE_GUIDE.md":
+        "d194b5c649e29a06b1b5d2b8438185b35674318d5c5410f1583df59b3782d570",
+}
+
+SHA256_RE = re.compile(r"^[0-9a-fA-F]{64}$")
+WINDOWS_ABS_RE = re.compile(r"^[A-Za-z]:[\\/]")
+
+
+class ContractError(ValueError):
+    pass
+
+
+def _json_load(path: Path) -> Any:
+    return json.loads(path.read_text(encoding="utf-8"))
+
+
+def _json_write(path: Path, value: Any) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(
+        json.dumps(value, indent=2, sort_keys=True, ensure_ascii=False) + "\n",
+        encoding="utf-8",
+        newline="\n",
+    )
+
+
+def _sha256(data: bytes) -> str:
+    return hashlib.sha256(data).hexdigest()
+
+
+def _require(condition: bool, message: str, errors: list[str]) -> None:
+    if not condition:
+        errors.append(message)
+
+
+def validate_change(change: Any, index: int = 0) -> list[str]:
+    errors: list[str] = []
+    prefix = f"changes[{index}]"
+    if not isinstance(change, Mapping):
+        return [f"{prefix} must be an object"]
+    action = change.get("action")
+    _require(isinstance(action, str) and bool(action), f"{prefix}.action is required", errors)
+    _require(
+        isinstance(change.get("path"), str) and bool(str(change.get("path") or "").strip()),
+        f"{prefix}.path is required",
+        errors,
+    )
+
+    if action == "write_file":
+        _require(isinstance(change.get("must_exist"), bool), f"{prefix}.must_exist must be boolean", errors)
+        before = change.get("expected_before_sha256")
+        _require(
+            before is None or (isinstance(before, str) and bool(SHA256_RE.fullmatch(before))),
+            f"{prefix}.expected_before_sha256 must be null or SHA-256",
+            errors,
+        )
+        _require(isinstance(change.get("content"), str), f"{prefix}.content must be a string", errors)
+        for forbidden in ("old", "new", "old_text", "new_text"):
+            _require(forbidden not in change, f"{prefix}.{forbidden} is not valid for write_file", errors)
+
+    elif action == "replace_text":
+        _require(change.get("must_exist") is True, f"{prefix}.must_exist must be true", errors)
+        before = change.get("expected_before_sha256")
+        _require(
+            isinstance(before, str) and bool(SHA256_RE.fullmatch(before)),
+            f"{prefix}.expected_before_sha256 must be a SHA-256 string",
+            errors,
+        )
+        _require(
+            isinstance(change.get("old"), str) and bool(change.get("old")),
+            f"{prefix}.old must be a non-empty string",
+            errors,
+        )
+        _require(isinstance(change.get("new"), str), f"{prefix}.new must be a string", errors)
+        _require("old_text" not in change, f"{prefix}.old_text is invalid; use old", errors)
+        _require("new_text" not in change, f"{prefix}.new_text is invalid; use new", errors)
+
+    else:
+        errors.append(f"{prefix}.action unsupported: {action!r}")
+    return errors
+
+
+def validate_plan_document(plan: Any) -> dict[str, Any]:
+    errors: list[str] = []
+    if not isinstance(plan, Mapping):
+        return {"valid": False, "errors": ["Plan must be one JSON object."]}
+
+    _require(plan.get("schema") == "foxai.engineering.plan.v1", "schema must be foxai.engineering.plan.v1", errors)
+    mission = plan.get("mission_id")
+    _require(
+        isinstance(mission, str) and mission.startswith("ENG-"),
+        "mission_id must be a non-empty ENG- identifier",
+        errors,
+    )
+    _require(isinstance(plan.get("title"), str) and bool(plan.get("title")), "title is required", errors)
+    root = plan.get("project_root")
+    _require(
+        isinstance(root, str) and bool(WINDOWS_ABS_RE.match(root)),
+        "project_root must be an absolute Windows path",
+        errors,
+    )
+
+    changes = plan.get("changes")
+    _require(isinstance(changes, list) and bool(changes), "changes must be a non-empty list", errors)
+    if isinstance(changes, list):
+        for index, change in enumerate(changes):
+            errors.extend(validate_change(change, index))
+
+    validations = plan.get("validations")
+    _require(isinstance(validations, list) and bool(validations), "validations must be a non-empty list", errors)
+    if isinstance(validations, list):
+        for index, validation in enumerate(validations):
+            prefix = f"validations[{index}]"
+            if not isinstance(validation, Mapping):
+                errors.append(f"{prefix} must be an object")
+                continue
+            _require(
+                isinstance(validation.get("name"), str) and bool(validation.get("name")),
+                f"{prefix}.name is required",
+                errors,
+            )
+            argv = validation.get("argv")
+            _require(
+                isinstance(argv, list)
+                and bool(argv)
+                and all(isinstance(item, str) for item in argv),
+                f"{prefix}.argv must be a non-empty list of strings",
+                errors,
+            )
+            _require(
+                isinstance(validation.get("cwd"), str) and bool(validation.get("cwd")),
+                f"{prefix}.cwd is required",
+                errors,
+            )
+            timeout = validation.get("timeout_seconds")
+            _require(
+                isinstance(timeout, int) and 1 <= timeout <= 86400,
+                f"{prefix}.timeout_seconds must be 1..86400",
+                errors,
+            )
+
+    return {
+        "schema": "foxai.engineering.contract_bridge.plan_validation.v1",
+        "bridge_id": BRIDGE_ID,
+        "bridge_version": BRIDGE_VERSION,
+        "valid": not errors,
+        "errors": errors,
+        "mission_id": plan.get("mission_id") if isinstance(plan, Mapping) else None,
+        "actions": [
+            change.get("action")
+            for change in changes
+            if isinstance(change, Mapping)
+        ] if isinstance(changes, list) else [],
+    }
+
+
+def validate_plan_file(path: Path) -> dict[str, Any]:
+    try:
+        plan = _json_load(path)
+    except Exception as exc:
+        return {
+            "schema": "foxai.engineering.contract_bridge.plan_validation.v1",
+            "valid": False,
+            "errors": [f"{type(exc).__name__}: {exc}"],
+            "path": str(path),
+        }
+    result = validate_plan_document(plan)
+    result["path"] = str(path)
+    result["sha256"] = _sha256(path.read_bytes())
+    return result
+
+
+def check_folder(folder: Path, expected_name: str, required_file: str = "PLAN.json") -> dict[str, Any]:
+    errors: list[str] = []
+    _require(folder.is_dir(), f"Folder does not exist: {folder}", errors)
+    if folder.is_dir():
+        _require(folder.name == expected_name, f"Expected folder name {expected_name}, found {folder.name}", errors)
+        _require((folder / required_file).is_file(), f"Missing {required_file} directly inside {folder}", errors)
+    return {
+        "schema": "foxai.engineering.contract_bridge.folder_check.v1",
+        "valid": not errors,
+        "errors": errors,
+        "folder": str(folder),
+        "expected_name": expected_name,
+        "required_file": required_file,
+    }
+
+
+def check_zip(path: Path, expected_root: str, required_file: str = "PLAN.json") -> dict[str, Any]:
+    errors: list[str] = []
+    members: list[str] = []
+    if not path.is_file():
+        errors.append(f"ZIP does not exist: {path}")
+    else:
+        try:
+            with zipfile.ZipFile(path) as archive:
+                members = archive.namelist()
+        except Exception as exc:
+            errors.append(f"{type(exc).__name__}: {exc}")
+
+    normalized_root = expected_root.rstrip("/") + "/"
+    for member in members:
+        pure = PurePosixPath(member)
+        if pure.is_absolute() or ".." in pure.parts:
+            errors.append(f"Unsafe ZIP member: {member}")
+        if not member.startswith(normalized_root):
+            errors.append(f"Member outside expected root {expected_root}: {member}")
+    if members:
+        _require(
+            f"{normalized_root}{required_file}" in members,
+            f"Missing {expected_root}/{required_file}",
+            errors,
+        )
+    return {
+        "schema": "foxai.engineering.contract_bridge.zip_check.v1",
+        "valid": not errors,
+        "errors": sorted(set(errors)),
+        "path": str(path),
+        "expected_root": expected_root,
+        "members": members,
+    }
+
+
+def _ast_inventory(path: Path, text: str) -> dict[str, Any]:
+    try:
+        tree = ast.parse(text, filename=str(path))
+    except Exception as exc:
+        return {
+            "parsed": False,
+            "parse_error": f"{type(exc).__name__}: {exc}",
+            "module_names": [],
+            "functions": [],
+            "classes": [],
+            "imports": [],
+        }
+
+    module_names: set[str] = set()
+    imports: list[dict[str, Any]] = []
+    functions: list[dict[str, Any]] = []
+    classes: list[dict[str, Any]] = []
+
+    for node in tree.body:
+        if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):
+            module_names.add(node.name)
+            functions.append({
+                "name": node.name,
+                "line": node.lineno,
+                "end_line": getattr(node, "end_lineno", node.lineno),
+                "arguments": [
+                    arg.arg for arg in (
+                        list(node.args.posonlyargs)
+                        + list(node.args.args)
+                        + list(node.args.kwonlyargs)
+                    )
+                ],
+                "vararg": node.args.vararg.arg if node.args.vararg else None,
+                "kwarg": node.args.kwarg.arg if node.args.kwarg else None,
+            })
+        elif isinstance(node, ast.ClassDef):
+            module_names.add(node.name)
+            classes.append({
+                "name": node.name,
+                "line": node.lineno,
+                "end_line": getattr(node, "end_lineno", node.lineno),
+                "methods": [
+                    child.name
+                    for child in node.body
+                    if isinstance(child, (ast.FunctionDef, ast.AsyncFunctionDef))
+                ],
+            })
+        elif isinstance(node, (ast.Assign, ast.AnnAssign)):
+            targets = node.targets if isinstance(node, ast.Assign) else [node.target]
+            for target in targets:
+                for name in _target_names(target):
+                    module_names.add(name)
+        elif isinstance(node, ast.Import):
+            for alias in node.names:
+                name = alias.asname or alias.name.split(".")[0]
+                module_names.add(name)
+                imports.append({"module": alias.name, "as": alias.asname, "line": node.lineno})
+        elif isinstance(node, ast.ImportFrom):
+            for alias in node.names:
+                name = alias.asname or alias.name
+                module_names.add(name)
+                imports.append({
+                    "module": node.module,
+                    "name": alias.name,
+                    "as": alias.asname,
+                    "line": node.lineno,
+                })
+
+    return {
+        "parsed": True,
+        "parse_error": None,
+        "module_names": sorted(module_names),
+        "functions": functions,
+        "classes": classes,
+        "imports": imports,
+    }
+
+
+def _target_names(target: ast.AST) -> set[str]:
+    names: set[str] = set()
+    if isinstance(target, ast.Name):
+        names.add(target.id)
+    elif isinstance(target, (ast.Tuple, ast.List)):
+        for item in target.elts:
+            names.update(_target_names(item))
+    return names
+
+
+def _file_record(project_root: Path, relative_path: str) -> dict[str, Any]:
+    path = project_root / Path(relative_path)
+    record: dict[str, Any] = {
+        "relative_path": relative_path,
+        "path": str(path),
+        "exists": path.is_file(),
+    }
+    if not path.is_file():
+        record.update({"size_bytes": None, "sha256": None})
+        return record
+    data = path.read_bytes()
+    record.update({"size_bytes": len(data), "sha256": _sha256(data)})
+    try:
+        text = data.decode("utf-8")
+        record["utf8"] = True
+    except UnicodeDecodeError as exc:
+        record.update({"utf8": False, "decode_error": str(exc)})
+        return record
+    if path.suffix.casefold() == ".py":
+        record["python"] = _ast_inventory(path, text)
+    return record
+
+
+def _usage_strings(text: str) -> list[dict[str, Any]]:
+    rows: list[dict[str, Any]] = []
+    for number, line in enumerate(text.splitlines(), 1):
+        if "Use: workshop " in line:
+            start = line.find("Use: workshop ")
+            value = line[start:].strip().strip("'\" )")
+            rows.append({"line": number, "usage": value, "source_line": line[:500]})
+    return rows
+
+
+def _action_evidence(text: str) -> list[dict[str, Any]]:
+    patterns = (
+        "write_file",
+        "replace_text",
+        "old_text",
+        "new_text",
+        'get("old")',
+        "get('old')",
+        'get("new")',
+        "get('new')",
+        "requires non-empty old",
+    )
+    rows: list[dict[str, Any]] = []
+    for number, line in enumerate(text.splitlines(), 1):
+        hits = [pattern for pattern in patterns if pattern in line]
+        if hits:
+            rows.append({"line": number, "hits": hits, "text": line[:600]})
+    return rows
+
+
+def inspect_current(project_root: Path) -> dict[str, Any]:
+    files = [_file_record(project_root, rel) for rel in FIXED_CURRENT_SOURCE_CANDIDATES]
+    by_rel = {row["relative_path"]: row for row in files}
+
+    bridge_path = project_root / "core/engineering_workshop_bridge.py"
+    patch_path = project_root / "Departments/Engineering/patch_engine.py"
+    bridge_text = bridge_path.read_text(encoding="utf-8") if bridge_path.is_file() else ""
+    patch_text = patch_path.read_text(encoding="utf-8") if patch_path.is_file() else ""
+
+    reference_checks = {}
+    for relative, expected in AUTHORITATIVE_REFERENCE_HASHES.items():
+        actual = by_rel.get(relative, {}).get("sha256")
+        reference_checks[relative] = {
+            "expected_sha256": expected,
+            "actual_sha256": actual,
+            "verified": actual == expected,
+        }
+
+    action_evidence = _action_evidence(patch_text)
+    actions_seen = sorted({
+        action
+        for action in ("write_file", "replace_text")
+        if any(action in row["hits"] or action in row["text"] for row in action_evidence)
+    })
+    usage = _usage_strings(bridge_text)
+
+    return {
+        "schema": "foxai.engineering.contract_bridge.current_inspection.v1",
+        "bridge_id": BRIDGE_ID,
+        "bridge_version": BRIDGE_VERSION,
+        "project_root": str(project_root),
+        "fixed_file_list_only": True,
+        "filesystem_walk_performed": False,
+        "files": files,
+        "workshop_bridge_found": bridge_path.is_file(),
+        "patch_engine_found": patch_path.is_file(),
+        "action_evidence": action_evidence,
+        "actions_seen": actions_seen,
+        "command_usage_evidence": usage,
+        "reference_checks": reference_checks,
+        "all_reference_hashes_verified": all(row["verified"] for row in reference_checks.values()),
+    }
+
+
+def _function_context(tree: ast.Module, target_line: int) -> Optional[ast.AST]:
+    candidates: list[ast.AST] = []
+    for node in ast.walk(tree):
+        if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):
+            start = node.lineno
+            end = getattr(node, "end_lineno", start)
+            if start <= target_line <= end:
+                candidates.append(node)
+    if not candidates:
+        return None
+    candidates.sort(key=lambda node: getattr(node, "end_lineno", node.lineno) - node.lineno)
+    return candidates[0]
+
+
+def _scope_names(node: Optional[ast.AST]) -> set[str]:
+    if node is None:
+        return set()
+    names: set[str] = set()
+    if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):
+        for arg in list(node.args.posonlyargs) + list(node.args.args) + list(node.args.kwonlyargs):
+            names.add(arg.arg)
+        if node.args.vararg:
+            names.add(node.args.vararg.arg)
+        if node.args.kwarg:
+            names.add(node.args.kwarg.arg)
+    for child in ast.walk(node):
+        if isinstance(child, (ast.Assign, ast.AnnAssign, ast.NamedExpr)):
+            targets = child.targets if isinstance(child, ast.Assign) else [child.target]
+            for target in targets:
+                names.update(_target_names(target))
+        elif isinstance(child, ast.For):
+            names.update(_target_names(child.target))
+        elif isinstance(child, ast.With):
+            for item in child.items:
+                if item.optional_vars:
+                    names.update(_target_names(item.optional_vars))
+        elif isinstance(child, ast.ExceptHandler) and child.name:
+            names.add(child.name)
+        elif isinstance(child, (ast.Import, ast.ImportFrom)):
+            if isinstance(child, ast.Import):
+                for alias in child.names:
+                    names.add(alias.asname or alias.name.split(".")[0])
+            else:
+                for alias in child.names:
+                    names.add(alias.asname or alias.name)
+    return names
+
+
+def assumed_symbols_for_replacement(source_text: str, old: str, new: str) -> dict[str, Any]:
+    if source_text.count(old) != 1:
+        return {
+            "valid_anchor": False,
+            "error": f"Expected old text exactly once, found {source_text.count(old)}",
+            "missing_assumed_symbols": [],
+        }
+    old_start_line = source_text[:source_text.index(old)].count("\n") + 1
+    source_tree = ast.parse(source_text)
+    inventory = _ast_inventory(Path("<source>"), source_text)
+    module_names = set(inventory.get("module_names") or [])
+    context = _function_context(source_tree, old_start_line)
+    context_names = _scope_names(context)
+
+    wrapper = "def __contract_bridge_snippet__():\n" + textwrap_indent(new, "    ")
+    snippet_tree = ast.parse(wrapper)
+    function = snippet_tree.body[0]
+    snippet_assigned = _scope_names(function)
+    snippet_loaded = {
+        node.id
+        for node in ast.walk(function)
+        if isinstance(node, ast.Name) and isinstance(node.ctx, ast.Load)
+    }
+    allowed = (
+        module_names
+        | context_names
+        | snippet_assigned
+        | set(dir(builtins))
+        | {"True", "False", "None"}
+    )
+    missing = sorted(snippet_loaded - allowed)
+    return {
+        "valid_anchor": True,
+        "old_start_line": old_start_line,
+        "context_function": getattr(context, "name", None),
+        "module_names_available": sorted(module_names),
+        "context_names_available": sorted(context_names),
+        "snippet_loaded_names": sorted(snippet_loaded),
+        "snippet_assigned_names": sorted(snippet_assigned),
+        "missing_assumed_symbols": missing,
+    }
+
+
+def textwrap_indent(text: str, prefix: str) -> str:
+    return "".join(prefix + line if line.strip() else prefix.rstrip() + "\n" for line in text.splitlines(True))
+
+
+def apply_plan_to_temp(plan: Mapping[str, Any], project_root: Path) -> dict[str, Any]:
+    validation = validate_plan_document(plan)
+    if not validation["valid"]:
+        return {
+            "schema": "foxai.engineering.contract_bridge.patch_validation.v1",
+            "valid": False,
+            "errors": validation["errors"],
+        }
+
+    temp_root = Path(tempfile.mkdtemp(prefix="foxai_contract_bridge_patch_"))
+    errors: list[str] = []
+    changed: list[dict[str, Any]] = []
+    assumed_symbol_findings: list[dict[str, Any]] = []
+
+    try:
+        for index, change in enumerate(plan["changes"]):
+            relative = str(change["path"]).replace("\\", "/")
+            source = project_root / Path(relative)
+            target = temp_root / Path(relative)
+            target.parent.mkdir(parents=True, exist_ok=True)
+
+            if source.is_file():
+                data = source.read_bytes()
+                target.write_bytes(data)
+            elif change["action"] == "replace_text" or change.get("must_exist"):
+                errors.append(f"Required source missing: {relative}")
+                continue
+
+            if change["action"] == "write_file":
+                before = target.read_bytes() if target.is_file() else None
+                expected = change.get("expected_before_sha256")
+                if expected is not None:
+                    actual = _sha256(before or b"")
+                    if actual != expected:
+                        errors.append(f"Preimage hash mismatch: {relative}")
+                        continue
+                target.write_text(change["content"], encoding="utf-8", newline="\n")
+
+            elif change["action"] == "replace_text":
+                before = target.read_bytes()
+                actual = _sha256(before)
+                if actual != change["expected_before_sha256"]:
+                    errors.append(f"Preimage hash mismatch: {relative}")
+                    continue
+                source_text = before.decode("utf-8")
+                symbol_finding = assumed_symbols_for_replacement(
+                    source_text, change["old"], change["new"]
+                )
+                symbol_finding["path"] = relative
+                assumed_symbol_findings.append(symbol_finding)
+                if symbol_finding.get("missing_assumed_symbols"):
+                    errors.append(
+                        f"Undefined/assumed symbols in replacement {relative}: "
+                        + ", ".join(symbol_finding["missing_assumed_symbols"])
+                    )
+                    continue
+                if source_text.count(change["old"]) != 1:
+                    errors.append(f"Replace anchor count is not one: {relative}")
+                    continue
+                target.write_text(
+                    source_text.replace(change["old"], change["new"], 1),
+                    encoding="utf-8",
+                    newline="\n",
+                )
+
+            if target.suffix.casefold() == ".py":
+                try:
+                    compile(target.read_text(encoding="utf-8"), str(target), "exec")
+                except Exception as exc:
+                    errors.append(f"Compile failed {relative}: {type(exc).__name__}: {exc}")
+
+            changed.append({
+                "path": relative,
+                "temporary_path": str(target),
+                "sha256": _sha256(target.read_bytes()) if target.is_file() else None,
+            })
+
+        return {
+            "schema": "foxai.engineering.contract_bridge.patch_validation.v1",
+            "valid": not errors,
+            "errors": errors,
+            "temporary_root": str(temp_root),
+            "project_modified": False,
+            "changes_tested": changed,
+            "assumed_symbol_findings": assumed_symbol_findings,
+        }
+    except Exception:
+        shutil.rmtree(temp_root, ignore_errors=True)
+        raise
+
+
+def symbol_inventory(project_root: Path, files: Iterable[str]) -> dict[str, Any]:
+    rows = [_file_record(project_root, str(relative)) for relative in files]
+    return {
+        "schema": "foxai.engineering.contract_bridge.symbol_inventory.v1",
+        "project_root": str(project_root),
+        "fixed_file_list_only": True,
+        "filesystem_walk_performed": False,
+        "files": rows,
+    }
