+def self_test(bridge_root: Path) -> dict[str, Any]:
+    fixtures = _json_load(bridge_root / FIXTURES_NAME)
+    failures: list[str] = []
+    cases = fixtures.get("cases") or []
+
+    base_plan = {
+        "schema": "foxai.engineering.plan.v1",
+        "mission_id": "ENG-TEST-0001",
+        "title": "Fixture",
+        "project_root": r"Z:\FOXAI",
+        "changes": [],
+        "validations": [{
+            "name": "fixture",
+            "argv": ["python", "-c", "print('ok')"],
+            "cwd": r"Z:\FOXAI",
+            "timeout_seconds": 30,
+        }],
+    }
+    for case in cases:
+        plan = dict(base_plan)
+        plan["changes"] = [case["change"]]
+        result = validate_plan_document(plan)
+        expected = case["expect"] == "pass"
+        if result["valid"] is not expected:
+            failures.append(case["id"])
+
+    temp = Path(tempfile.mkdtemp(prefix="contract_bridge_self_test_"))
+    try:
+        wrong_root_zip = temp / "wrong.zip"
+        with zipfile.ZipFile(wrong_root_zip, "w") as archive:
+            archive.writestr("WRONG/PLAN.json", "{}")
+        if check_zip(wrong_root_zip, "RIGHT")["valid"]:
+            failures.append("wrong_zip_root_not_rejected")
+
+        good_folder = temp / "RIGHT"
+        good_folder.mkdir()
+        (good_folder / "PLAN.json").write_text("{}", encoding="utf-8")
+        if not check_folder(good_folder, "RIGHT")["valid"]:
+            failures.append("correct_folder_rejected")
+
+        source = (
+            "from pathlib import Path\n"
+            "KNOWN = 1\n"
+            "def route_message(message):\n"
+            "    value = message\n"
+            "    return value\n"
+        )
+        old = "    value = message\n    return value"
+        bad_new = "    value = message\n    return ADAPTER_ID"
+        finding = assumed_symbols_for_replacement(source, old, bad_new)
+        if "ADAPTER_ID" not in finding["missing_assumed_symbols"]:
+            failures.append("undefined_symbol_not_detected")
+
+        real_contract = {"required": ["handled", "status"]}
+        mapping = {"handled": True, "status": "ok"}
+        if not all(field in mapping for field in real_contract["required"]):
+            failures.append("optional_fields_incorrectly_required")
+
+        project = temp / "project"
+        project.mkdir()
+        module = project / "module.py"
+        module.write_text(source, encoding="utf-8")
+        good_new = "    value = message\n    return KNOWN"
+        plan = dict(base_plan)
+        plan["project_root"] = r"Z:\\FOXAI"
+        plan["changes"] = [{
+            "action": "replace_text",
+            "path": "module.py",
+            "must_exist": True,
+            "expected_before_sha256": _sha256(module.read_bytes()),
+            "old": old,
+            "new": good_new,
+        }]
+        patch_result = apply_plan_to_temp(plan, project)
+        if not patch_result["valid"]:
+            failures.append("real_source_temp_patch_failed")
+        if module.read_text(encoding="utf-8") != source:
+            failures.append("project_was_modified_by_temp_patch")
+        if patch_result.get("temporary_root"):
+            shutil.rmtree(Path(patch_result["temporary_root"]), ignore_errors=True)
+    finally:
+        shutil.rmtree(temp, ignore_errors=True)
+
+    return {
+        "schema": "foxai.engineering.contract_bridge.self_test.v1",
+        "bridge_id": BRIDGE_ID,
+        "bridge_version": BRIDGE_VERSION,
+        "passed": not failures,
+        "fixture_cases": len(cases),
+        "failures": failures,
+    }
+
+
+def _print(value: Any) -> None:
+    print(json.dumps(value, indent=2, sort_keys=True, ensure_ascii=False))
+
+
+def main(argv: Optional[list[str]] = None) -> int:
+    parser = argparse.ArgumentParser(description="FOXAI Workshop Contract and Reference Bridge V1")
+    sub = parser.add_subparsers(dest="command", required=True)
+
+    p = sub.add_parser("validate-plan")
+    p.add_argument("plan")
+
+    p = sub.add_parser("check-folder")
+    p.add_argument("folder")
+    p.add_argument("--expected-name", required=True)
+    p.add_argument("--required-file", default="PLAN.json")
+
+    p = sub.add_parser("check-zip")
+    p.add_argument("zip")
+    p.add_argument("--expected-root", required=True)
+    p.add_argument("--required-file", default="PLAN.json")
+
+    p = sub.add_parser("inspect-current")
+    p.add_argument("--project-root", required=True)
+    p.add_argument("--output")
+
+    p = sub.add_parser("symbol-inventory")
+    p.add_argument("--project-root", required=True)
+    p.add_argument("--files-json", required=True)
+    p.add_argument("--output")
+
+    p = sub.add_parser("export-capsule")
+    p.add_argument("--request", required=True)
+    p.add_argument("--output", required=True)
+
+    p = sub.add_parser("validate-patch")
+    p.add_argument("--plan", required=True)
+    p.add_argument("--project-root", required=True)
+    p.add_argument("--output")
+
+    p = sub.add_parser("explain-receipt")
+    p.add_argument("receipt")
+    p.add_argument("--output")
+
+    sub.add_parser("self-test")
+
+    args = parser.parse_args(argv)
+    bridge_root = Path(__file__).resolve().parent
+
+    if args.command == "validate-plan":
+        result = validate_plan_file(Path(args.plan))
+    elif args.command == "check-folder":
+        result = check_folder(Path(args.folder), args.expected_name, args.required_file)
+    elif args.command == "check-zip":
+        result = check_zip(Path(args.zip), args.expected_root, args.required_file)
+    elif args.command == "inspect-current":
+        result = inspect_current(Path(args.project_root))
+        if args.output:
+            _json_write(Path(args.output), result)
+    elif args.command == "symbol-inventory":
+        value = _json_load(Path(args.files_json))
+        files = value.get("files") if isinstance(value, Mapping) else value
+        if not isinstance(files, list):
+            raise ContractError("files-json must be a list or an object containing files.")
+        result = symbol_inventory(Path(args.project_root), [str(item) for item in files])
+        if args.output:
+            _json_write(Path(args.output), result)
+    elif args.command == "export-capsule":
+        result = export_capsule(
+            Path(args.request),
+            Path(args.output),
+            bridge_root,
+        )
+    elif args.command == "validate-patch":
+        plan = _json_load(Path(args.plan))
+        result = apply_plan_to_temp(plan, Path(args.project_root))
+        if args.output:
+            _json_write(Path(args.output), result)
+    elif args.command == "explain-receipt":
+        result = explain_receipt(Path(args.receipt))
+        if args.output:
+            _json_write(Path(args.output), result)
+    elif args.command == "self-test":
+        result = self_test(bridge_root)
+    else:
+        raise AssertionError(args.command)
+
+    _print(result)
+    return 0 if result.get("valid", result.get("passed", True)) else 1
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
