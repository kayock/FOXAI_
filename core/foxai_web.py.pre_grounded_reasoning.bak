${d.latest_recovery_event}

Advisories:
${(d.advisories||[]).length ? (d.advisories||[]).map(a=>`${a.id}: ${a.summary} — ${a.recommended_action}`).join('\n') : 'None.'}

Attention:
${(d.attention||[]).length ? (d.attention||[]).map(a=>`${a.id}: ${a.summary} — ${a.recommended_action}`).join('\n') : 'None.'}

