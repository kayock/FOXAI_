Rollback allowed now: ${s.rollback_allowed_now}
Would overwrite: ${s.would_overwrite}
${d.exported?`Markdown: ${d.exported.markdown}
JSON: ${d.exported.json}`:''}`;
    q('rollbackPreviewDashboard').innerHTML=`<div class=historygrid>
