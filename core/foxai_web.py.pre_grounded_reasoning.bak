<span class="pill ${s.chat_online?'ok':'warn'}">Chat ${s.chat_online?'Running':'Stopped'}</span><br><span class="pill ${s.comfy_online?'ok':'warn'}">ComfyUI ${s.comfy_online?'Running':'Stopped'}</span>`;renderRepairGuidedStatus(s)}

async function refreshComfyOperations(){
    const meta=q('comfyOpsMeta');
    const log=q('comfyOpsLog');
    const fill=q('comfyOpsFill');
    const title=q('comfyOpsTitle');
    if(!meta||!log||!fill||!title)return;
    try{
        const response=await fetch('/api/comfy/operations',{cache:'no-store'});
        const d=await response.json();
        const online=!!d?.online;
        const state=String(d?.state||'UNKNOWN');
        const pct=Number.isInteger(d?.progress_percent)
            ?d.progress_percent:null;
        title.textContent=`COMFYUI OPERATIONS // ${state}${pct!==null?' '+pct+'%':''}`;
        meta.textContent=`Endpoint: 127.0.0.1:8188  |  Health: ${online?'ONLINE':'OFFLINE'}\nLog: ${d?.log_path||'No live log located'}\nUpdated: ${d?.log_modified||'—'}`;
        fill.style.width=`${Math.max(0,Math.min(100,pct||0))}%`;
        const next=String(
            d?.tail
            ||d?.message
            ||'No ComfyUI console output has been captured yet.'
        );
        if(log.textContent!==next){
            log.textContent=next;
            log.scrollTop=log.scrollHeight;
        }
    }catch(error){
        title.textContent='COMFYUI OPERATIONS // MONITOR ERROR';
        meta.textContent=String(error);
    }
}

