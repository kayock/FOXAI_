def _inventory_read_json(path,default):
    path=Path(path)
    if not path.is_file():
        return default,f'Missing file: {path}'
    try:
        data=json.loads(path.read_text(encoding='utf-8'))
    except Exception as exc:
        return default,f'{type(exc).__name__}: {exc}'
    return data,None

def _inventory_resolve_path(value):
    if value is None or str(value).strip()=='':
        return None
    text=os.path.expandvars(str(value).strip())
    path=Path(text)
    if not path.is_absolute():
        path=ROOT/path
    try:
        return path.resolve()
    except Exception:
        return path

def _inventory_relative(path):
    if path is None:
        return ''
    try:
        return str(Path(path).resolve().relative_to(ROOT.resolve())).replace('\\','/')
    except Exception:
        return str(path)

def _inventory_file_details(path):
    path=Path(path) if path is not None else None
    if path is None:
        return {'exists':False,'is_file':False,'is_dir':False,'size_bytes':None,'modified':None}
    try:
        exists=path.exists()
        is_file=path.is_file()
        is_dir=path.is_dir()
        stat=path.stat() if exists else None
        return {
            'exists':exists,
            'is_file':is_file,
            'is_dir':is_dir,
            'size_bytes':stat.st_size if is_file and stat else None,
            'modified':datetime.fromtimestamp(stat.st_mtime).isoformat(timespec='seconds') if stat else None,
        }
    except Exception as exc:
        return {'exists':False,'is_file':False,'is_dir':False,'size_bytes':None,'modified':None,'error':f'{type(exc).__name__}: {exc}'}

def _inventory_manifest_candidates():
    files=[]
    ignored={'__pycache__','.git','node_modules','backups','backup'}
    for base in (ROOT/'Departments',ROOT/'Extensions',ROOT/'Modules'):
        if not base.exists():
            continue
        try:
            for path in base.rglob('*'):
                if not path.is_file() or path.name.lower() not in {'manifest.json','module.json','extension.json'}:
                    continue
                lowered={part.lower() for part in path.parts}
                if lowered & ignored:
                    continue
                files.append(path)
        except Exception:
            continue
    seen=set()
    result=[]
    for path in sorted(files,key=lambda p:str(p).casefold()):
        try:
            key=str(path.resolve()).casefold()
        except Exception:
            key=str(path).casefold()
        if key not in seen:
            seen.add(key)
            result.append(path)
    return result

def _inventory_manifest_records():
    records=[]
    for path in _inventory_manifest_candidates():
        raw,error=_inventory_read_json(path,{})
        if not isinstance(raw,dict):
            raw={}
            error=error or 'Manifest root is not an object.'
        key=str(raw.get('id') or raw.get('key') or raw.get('name') or extension_key_from_path(path)).strip()
        name=str(raw.get('name') or raw.get('title') or path.parent.name).strip()
        version=str(raw.get('version') or '').strip()
        kind=str(raw.get('type') or raw.get('kind') or ('department' if 'departments' in {part.lower() for part in path.parts} else 'extension')).strip().lower()
        required_fields=['name','version']
        missing=[field for field in required_fields if not str(raw.get(field) or '').strip()]
        missing_tools=[]
        for tool in raw.get('tools') or []:
            if not isinstance(tool,dict):
                continue
            import_name=str(tool.get('import') or '').strip()
            if import_name:
                try:
                    if importlib.util.find_spec(import_name) is None:
                        missing_tools.append(import_name)
                except Exception:
                    missing_tools.append(import_name)
        enabled=bool(raw.get('enabled',True))
        required=bool(kind=='department' and enabled)
        records.append({
            'key':key,
            'name':name,
            'version':version or 'Unspecified',
            'kind':kind,
            'required':required,
            'enabled_default':enabled,
            'description':str(raw.get('description') or raw.get('summary') or '').strip(),
            'department':str(raw.get('department') or '').strip(),
            'manifest_path':path,
            'folder_path':path.parent,
            'raw':raw,
            'error':error,
            'missing_fields':missing,
            'missing_tools':sorted(set(missing_tools)),
        })
    return records

def _inventory_status(*,exists,required=False,manifest_ok=True,live=None,verified_contract=False,mismatch=False):
    if mismatch or not manifest_ok:
        return 'NEEDS_ATTENTION'
    if not exists:
        return 'NEEDS_ATTENTION' if required else 'MISSING'
    if live is True or verified_contract:
        return 'VERIFIED'
    return 'INSTALLED'

def _inventory_item(item_id,name,category,source,path=None,version='Unspecified',required=False,status='INSTALLED',health='',description='',department='',kind='',manifest_path=None,verification_basis='',actions=None,extra=None):
    details=_inventory_file_details(path)
    item={
        'id':str(item_id),
        'name':str(name),
        'category':str(category),
        'source':str(source),
        'path':str(path) if path is not None else '',
        'relative_path':_inventory_relative(path),
        'version':str(version or 'Unspecified'),
        'required':bool(required),
        'status':str(status),
        'health':str(health or ''),
        'description':str(description or ''),
        'department':str(department or ''),
        'kind':str(kind or ''),
        'exists':bool(details.get('exists')),
        'is_file':bool(details.get('is_file')),
        'is_dir':bool(details.get('is_dir')),
        'size_bytes':details.get('size_bytes'),
        'modified':details.get('modified'),
        'manifest_path':str(manifest_path) if manifest_path else '',
        'verification_basis':str(verification_basis or ''),
        'actions':dict(actions or {}),
    }
    if details.get('error'):
        item['path_error']=details['error']
    if isinstance(extra,dict):
        item.update(extra)
    return item

def _inventory_application_items(registry):
    items=[]
    applications=registry.get('applications') if isinstance(registry,dict) else []
    for app in applications or []:
        if not isinstance(app,dict):
            continue
        app_id=str(app.get('id') or slug(app.get('name') or 'application')).strip()
        path=_inventory_resolve_path(app.get('path'))
        details=_inventory_file_details(path)
        lifecycle=str(app.get('lifecycle') or 'unknown').strip().lower()
        required=lifecycle=='active'
        mode=str(app.get('health_mode') or 'path').strip().lower()
        url=str(app.get('url') or '').strip()
        live=None
        if mode=='http' and url.lower().startswith(('http://127.0.0.1','http://localhost')):
            live=check(url)
        exists=bool(details.get('exists'))
        verified_contract=bool(exists and mode in {'path','component'})
        status=_inventory_status(
            exists=exists,
            required=required,
            live=live,
            verified_contract=verified_contract,
        )
        if live is True:
            health='Local health endpoint responded.'
            basis='localhost health endpoint + registered path'
        elif exists and mode=='http':
            health='Installed; local service is not currently responding.'
            basis='registered path exists'
        elif exists:
            health='Registered path exists.'
            basis='application registry + path existence'
        elif required:
            health='Active application path is missing.'
            basis='application registry required path'
        else:
            health=f'{lifecycle.title()} application is not installed yet.'
            basis='application registry lifecycle'
        actions={'open_folder':exists}
        if app_id=='comfyui' and exists:
            actions['launch']=True
            actions['launch_label']='Start ComfyUI'
        if url.lower().startswith(('http://127.0.0.1','http://localhost')):
            actions['open_url']=True
        items.append(_inventory_item(
            f'app:{app_id}',
            app.get('name') or app_id,
            'Application / Runtime',
            'Application Registry',
            path=path,
            version=app.get('version') or 'Registry entry',
            required=required,
            status=status,
            health=health,
            description=app.get('notes') or '',
            department=app.get('department') or '',
            kind=app.get('kind') or '',
            verification_basis=basis,
            actions=actions,
            extra={
                'lifecycle':lifecycle,
                'health_mode':mode,
                'url':url,
                'security_role':str(app.get('security_role') or ''),
                'live':live,
            },
        ))
    return items

def _inventory_fleet_items(registry,manifest_by_key,manifest_by_path=None):
    items=[]
    consumed=set()
    shuttles=registry.get('shuttles') if isinstance(registry,dict) else {}
    for key,entry in sorted((shuttles or {}).items(),key=lambda pair:str(pair[0]).casefold()):
        if not isinstance(entry,dict):
            continue
        key=str(entry.get('key') or key)
        path=_inventory_resolve_path(entry.get('path'))
        manifest_path=_inventory_resolve_path(entry.get('manifest_path'))
        manifest=manifest_by_key.get(key.casefold())
        if manifest is None and manifest_path is not None and isinstance(manifest_by_path,dict):
            try:
                manifest=manifest_by_path.get(str(manifest_path.resolve()).casefold())
            except Exception:
                manifest=manifest_by_path.get(str(manifest_path).casefold())
        if manifest:
            consumed.add(str(manifest['manifest_path']).casefold())
        details=_inventory_file_details(path)
        manifest_exists=bool(manifest_path and manifest_path.is_file())
        installed_flag=bool(entry.get('installed'))
        mismatch=bool(installed_flag != bool(details.get('exists')))
        manifest_ok=bool(manifest_exists and not (manifest or {}).get('missing_fields') and not (manifest or {}).get('error'))
        status=_inventory_status(
            exists=bool(details.get('exists')),
            required=False,
            manifest_ok=manifest_ok,
            verified_contract=bool(installed_flag and details.get('exists') and manifest_ok),
            mismatch=mismatch,
        )
        if mismatch:
            health='Fleet registry installation flag does not match the executable path.'
        elif status=='VERIFIED':
            health=str(entry.get('health_message') or 'Executable and manifest are present.')
        elif status=='MISSING':
            health='Optional fleet tool is not installed.'
        else:
            health='Executable is present; manifest verification is incomplete.'
        actions={'open_folder':bool(details.get('exists'))}
        item_id=f'fleet:{key}'
        if item_id in EXTENSION_INVENTORY_SAFE_FLEET_LAUNCH and details.get('exists'):
            actions['launch']=True
            actions['launch_label']='Launch'
        items.append(_inventory_item(
            item_id,
            entry.get('name') or key,
            'Optional Tool',
            'Fleet Registry',
            path=path,
            version=(manifest or {}).get('version') or 'Auto-detected',
            required=False,
            status=status,
            health=health,
            description=(manifest or {}).get('description') or '',
            department=entry.get('department') or '',
            kind=entry.get('kind') or 'application',
            manifest_path=manifest_path,
            verification_basis='fleet registry + executable path + manifest' if status=='VERIFIED' else 'fleet registry and passive path check',
            actions=actions,
            extra={
                'callsign':str(entry.get('callsign') or ''),
                'capabilities':list(entry.get('capabilities') or []),
                'installed_flag':installed_flag,
                'service_state':str(entry.get('service_state') or ''),
                'manifest_valid':manifest_ok,
                'registry_health_status':str(entry.get('health_status') or ''),
            },
        ))
    return items,consumed

def _inventory_manifest_items(records,consumed):
    items=[]
    for record in records:
        if str(record['manifest_path']).casefold() in consumed:
            continue
        manifest_ok=not record['error'] and not record['missing_fields']
        tools_ok=not record['missing_tools']
        status=_inventory_status(
            exists=record['manifest_path'].is_file(),
            required=record['required'],
            manifest_ok=manifest_ok and tools_ok,
            verified_contract=manifest_ok and tools_ok,
        )
        issues=[]
        if record['error']:
            issues.append(record['error'])
        if record['missing_fields']:
            issues.append('Missing fields: '+', '.join(record['missing_fields']))
        if record['missing_tools']:
            issues.append('Missing declared tools: '+', '.join(record['missing_tools']))
        health='Manifest and declared Python tools verified.' if status=='VERIFIED' else ('; '.join(issues) if issues else 'Manifest is present.')
        item_id='manifest:'+slug(record['key']).lower()+':'+hashlib.sha256(str(record['manifest_path']).encode()).hexdigest()[:8]
        items.append(_inventory_item(
            item_id,
            record['name'],
            'Department Manifest' if record['kind']=='department' else 'Extension Manifest',
            'Manifest Discovery',
            path=record['folder_path'],
            version=record['version'],
            required=record['required'],
            status=status,
            health=health,
            description=record['description'],
            department=record['department'],
            kind=record['kind'],
            manifest_path=record['manifest_path'],
            verification_basis='manifest schema + declared Python tool availability',
            actions={'open_folder':record['folder_path'].exists()},
            extra={
                'missing_fields':record['missing_fields'],
                'missing_tools':record['missing_tools'],
                'enabled_default':record['enabled_default'],
                'depends_on':list(record['raw'].get('depends_on') or []),
                'capabilities':list(record['raw'].get('capabilities') or record['raw'].get('provides') or []),
            },
        ))
    return items

def _inventory_core_items():
    items=[]
    for item_id,name,category,relative in EXTENSION_INVENTORY_CORE_FILES:
        path=ROOT/relative
        exists=path.is_file()
        status='VERIFIED' if exists else 'MISSING'
        health='Core registry module is present.' if exists else 'Optional registry runtime is not present in this build.'
        items.append(_inventory_item(
            item_id,name,category,'Core Runtime',
            path=path,
            version='Python module',
            required=False,
            status=status,
            health=health,
            kind='python_module',
            verification_basis='exact path existence',
            actions={'open_folder':exists},
        ))
    return items

def _inventory_model_items():
    items=[]
    seen=set()
    scanned=0
    truncated=False
    projector_count=0
    configured={
        str(spec.get('model_filename') or '').casefold()
        for spec in (globals().get('WEB_MODEL_PROFILE_RUNTIME') or {}).values()
        if isinstance(spec,dict) and spec.get('model_filename')
    }
    roots=[
        ('Chat Model',ROOT/'Models'/'Chat'),
        ('Chat Model',ROOT/'Models'),
        ('Creative Checkpoint',ROOT/'ComfyUI'/'models'/'checkpoints'),
        ('Creative LoRA',ROOT/'ComfyUI'/'models'/'loras'),
        ('Creative VAE',ROOT/'ComfyUI'/'models'/'vae'),
    ]
    for category,base in roots:
        if not base.exists():
            continue
        try:
            paths=base.rglob('*')
        except Exception:
            continue
        for path in paths:
            if scanned>=EXTENSION_INVENTORY_MAX_MODEL_FILES:
                truncated=True
                break
            if not path.is_file() or path.suffix.lower() not in EXTENSION_INVENTORY_MODEL_SUFFIXES:
                continue
            try:
                resolved=str(path.resolve()).casefold()
            except Exception:
                resolved=str(path).casefold()
            if resolved in seen:
                continue
            seen.add(resolved)
            scanned+=1
            is_projector='mmproj' in path.name.casefold() or 'projector' in path.name.casefold()
            item_category='Vision Projector' if is_projector else category
            if is_projector:
                projector_count+=1
            required=path.name.casefold() in configured or path.name==VISION_PROJECTOR_FILENAME
            expected=EXTENSION_INVENTORY_EXPECTED_SIZES.get(path.name)
            size=path.stat().st_size
            size_verified=expected is not None and size==expected
            mismatch=expected is not None and size!=expected
            status='NEEDS_ATTENTION' if mismatch else ('VERIFIED' if size_verified else 'INSTALLED')
            health=(
                f'Expected size verified: {expected} bytes.'
                if size_verified
                else (
                    f'Expected {expected} bytes but found {size}.'
                    if mismatch
                    else 'Model file is installed; passive inventory did not hash this large file.'
                )
            )
            basis='expected byte-size contract' if expected is not None else 'file existence and metadata only'
            items.append(_inventory_item(
                'model:'+_inventory_relative(path).casefold(),
                path.name,
                item_category,
                'Model Filesystem',
                path=path,
                version=path.suffix.lstrip('.').upper(),
                required=required,
                status=status,
                health=health,
                kind='vision_projector' if is_projector else 'model',
                verification_basis=basis,
                actions={'open_folder':True},
                extra={
                    'expected_size_bytes':expected,
                    'configured_profile_model':path.name.casefold() in configured,
                    'excluded_from_language_model_selector':is_projector,
                },
            ))
        if truncated:
            break
    return items,{
        'files_scanned':scanned,
        'truncated':truncated,
        'projectors_classified_separately':projector_count,
        'projectors_filtered_from_language_models':True,
    }

def extension_inventory_snapshot():
    application_path=ROOT/'Config'/'application_registry.json'
    fleet_path=ROOT/'Config'/'fleet_registry.json'
    state_path=ROOT/'Config'/'extension_state.json'
    application,error_app=_inventory_read_json(application_path,{})
    fleet,error_fleet=_inventory_read_json(fleet_path,{})
    manifests=_inventory_manifest_records()
    manifest_by_key={
        str(record['key']).casefold():record
        for record in manifests
        if record.get('key')
    }
    manifest_by_path={
        str(record['manifest_path'].resolve()).casefold():record
        for record in manifests
    }

    items=[]
    items.extend(_inventory_application_items(application))
    fleet_items,consumed=_inventory_fleet_items(fleet,manifest_by_key,manifest_by_path)
    items.extend(fleet_items)
    items.extend(_inventory_manifest_items(manifests,consumed))
    items.extend(_inventory_core_items())
    model_items,model_scan=_inventory_model_items()
    items.extend(model_items)

    status_order={'NEEDS_ATTENTION':0,'MISSING':1,'INSTALLED':2,'VERIFIED':3}
    items.sort(key=lambda item:(status_order.get(item.get('status'),9),str(item.get('category')).casefold(),str(item.get('name')).casefold()))

    counts={name:sum(1 for item in items if item.get('status')==name) for name in ('VERIFIED','INSTALLED','MISSING','NEEDS_ATTENTION')}
    categories={}
    for item in items:
        categories[item['category']]=categories.get(item['category'],0)+1
    required_items=[item for item in items if item.get('required')]
    required_problems=[
        item for item in required_items
        if item.get('status') in {'MISSING','NEEDS_ATTENTION'}
    ]
    sources={
        'application_registry':{
            'path':str(application_path),
            'exists':application_path.is_file(),
            'error':error_app,
            'records':len(application.get('applications') or []) if isinstance(application,dict) else 0,
        },
        'fleet_registry':{
            'path':str(fleet_path),
            'exists':fleet_path.is_file(),
            'error':error_fleet,
            'records':len(fleet.get('shuttles') or {}) if isinstance(fleet,dict) else 0,
            'mode':str(fleet.get('mode') or '') if isinstance(fleet,dict) else '',
        },
        'manifest_discovery':{
            'roots':[str(ROOT/'Departments'),str(ROOT/'Extensions'),str(ROOT/'Modules')],
            'records':len(manifests),
            'recursive':True,
        },
        'extension_state':{
            'path':str(state_path),
            'exists':state_path.is_file(),
            'mode':'explicit overrides' if state_path.is_file() else 'manifest defaults; no state file created',
        },
    }
    return {
        'ok':True,
        'created':now(),
        'read_only':True,
        'report_only':True,
        'configuration_modified':False,
        'state_file_created':False,
        'summary':{
            'total':len(items),
            'verified':counts['VERIFIED'],
            'installed':counts['INSTALLED'],
            'missing':counts['MISSING'],
            'needs_attention':counts['NEEDS_ATTENTION'],
            'required':len(required_items),
            'optional':len(items)-len(required_items),
            'required_problems':len(required_problems),
            'categories':categories,
            'model_scan':model_scan,
        },
        'sources':sources,
        'items':items,
        'safety':{
            'install':False,
            'remove':False,
            'update':False,
            'configuration_write':False,
            'folder_open':'operator initiated; backend path allowlist',
            'launch':'operator initiated; backend item allowlist only',
        },
        'message':f"Read-only inventory: {len(items)} component(s), {counts['NEEDS_ATTENTION']} needing attention.",
    }

def _inventory_lookup(item_id):
    item_id=str(item_id or '').strip()
    if not item_id:
        return None
    data=extension_inventory_snapshot()
    return next((item for item in data.get('items',[]) if item.get('id')==item_id),None)

def _inventory_allowed_path(path):
    path=_inventory_resolve_path(path)
    if path is None:
        return False
    try:
        resolved=path.resolve()
    except Exception:
        return False
    allowed=[ROOT.resolve()]
    hanger=DRIVE/'Hanger Bay'
    if hanger.exists():
        allowed.append(hanger.resolve())
    for base in allowed:
        try:
            resolved.relative_to(base)
            return True
        except Exception:
            continue
    return False

def open_extension_inventory_folder(d):
    item=_inventory_lookup(d.get('id') if isinstance(d,dict) else '')
    if not item:
        return {'ok':False,'message':'Inventory item not found. No folder was opened.'}
    path=_inventory_resolve_path(item.get('path') or item.get('manifest_path'))
    if path is None or not path.exists():
        return {'ok':False,'message':'Inventory path is missing. No folder was opened.'}
    folder=path if path.is_dir() else path.parent
    if not _inventory_allowed_path(folder):
        return {'ok':False,'message':'Inventory folder is outside the approved FOXAI / Hanger Bay roots.'}
    os.startfile(str(folder))
    receipt=make_tool_receipt(
        'shell.open_extension_inventory_folder',
        'requested',
        details={'item_id':item['id'],'path':str(folder)},
        actor='operator',
    )
    return {
        'ok':True,
        'message':f"Folder open request sent for {item['name']}; Explorer state is not verified.",
        'receipt':receipt,
        'claim_state':'requested',
    }

def open_extension_inventory_url(d):
    item=_inventory_lookup(d.get('id') if isinstance(d,dict) else '')
    if not item:
        return {'ok':False,'message':'Inventory item not found. No URL was opened.'}
    url=str(item.get('url') or '').strip()
    if not url.lower().startswith(('http://127.0.0.1','http://localhost')):
        return {'ok':False,'message':'Only registered localhost URLs may be opened from Phase 1 inventory.'}
    openurl(url)
    receipt=make_tool_receipt(
        'browser.open_extension_inventory_url',
        'requested',
        details={'item_id':item['id'],'url':url},
        actor='operator',
    )
    return {
        'ok':True,
        'message':f"Browser open request sent for {item['name']}; tab state is not verified.",
        'receipt':receipt,
        'claim_state':'requested',
    }

def launch_extension_inventory_item(d):
    item=_inventory_lookup(d.get('id') if isinstance(d,dict) else '')
    if not item:
        return {'ok':False,'message':'Inventory item not found. No process was launched.'}
    item_id=str(item.get('id') or '')
    if item_id=='app:comfyui':
        if not COMFY_MAIN.is_file():
            return {'ok':False,'message':'ComfyUI main.py is missing. No process was launched.'}
        result=comfy_normal_call('spawn',source='webui',timeout=330)
        receipt=make_tool_receipt(
            'comfy.start','verified' if result.get('ok') else 'blocked',
            checks=[{'id':'normal_controller','ok':bool(result.get('ok')),'message':str(result.get('message') or '')}],
            details={'state':result.get('state'),'source':'extension_inventory'},
            actor='operator',
        )
        return {'ok':bool(result.get('ok')),'message':str(result.get('message') or 'ComfyUI normal controller returned no message.'),'state':result.get('state'),'controller':result,'receipt':receipt,'claim_state':'verified' if result.get('ok') else 'blocked'}

    allowed_names=EXTENSION_INVENTORY_SAFE_FLEET_LAUNCH.get(item_id)
    path=_inventory_resolve_path(item.get('path'))
    if not allowed_names or path is None or not path.is_file():
        return {'ok':False,'message':'This inventory item is not in the Phase 1 launch allowlist.'}
    if path.name.casefold() not in {name.casefold() for name in allowed_names}:
        return {'ok':False,'message':'Executable identity does not match the Phase 1 launch allowlist.'}
    if not _inventory_allowed_path(path):
        return {'ok':False,'message':'Executable path is outside the approved FOXAI / Hanger Bay roots.'}
    proc=subprocess.Popen([str(path)],cwd=str(path.parent))
    receipt=make_tool_receipt(
        'extension_inventory.launch',
        'requested',
        details={'item_id':item_id,'path':str(path),'pid':getattr(proc,'pid',None)},
        actor='operator',
    )
    return {
        'ok':True,
        'message':f"Launch requested for {item['name']}; application state is not yet verified.",
        'receipt':receipt,
        'claim_state':'requested',
    }
# EXTENSION_MANAGER_INVENTORY_PHASE1_BACKEND_END

# EXTENSION_MANAGER_SAFE_STATE_PHASE2_BACKEND_START
EXTENSION_STATE_MAX_BYTES=64*1024
EXTENSION_STATE_RESERVED_KEYS={'_meta','schema','updated'}
EXTENSION_STATE_ACTIONS={'enable','disable','restore'}
extension_state_lock=RLock()
_extension_inventory_snapshot_phase1=extension_inventory_snapshot
_launch_extension_inventory_item_phase1=launch_extension_inventory_item

def _extension_state_path():
    return ROOT/'Config'/'extension_state.json'

def _extension_state_read():
    path=_extension_state_path()
    if not path.exists():
        return {},{'exists':False,'sha256':None,'size_bytes':0,'error':None}
    if not path.is_file():
        raise ValueError('extension_state.json is not a regular file.')
    size=path.stat().st_size
    if size>EXTENSION_STATE_MAX_BYTES:
        raise ValueError('extension_state.json exceeds the 64 KB safety limit.')
    try:
        raw=json.loads(path.read_text(encoding='utf-8'))
    except Exception as exc:
        raise ValueError(f'extension_state.json is invalid JSON: {exc}') from exc
    if not isinstance(raw,dict):
        raise ValueError('extension_state.json root must be an object.')
    seen=set()
    for key,value in raw.items():
        if key in EXTENSION_STATE_RESERVED_KEYS:
            continue
        folded=str(key).casefold()
        if folded in seen:
            raise ValueError('extension_state.json contains case-insensitive duplicate keys.')
        seen.add(folded)
        if not isinstance(value,dict) or not isinstance(value.get('enabled'),bool):
            raise ValueError(f'Invalid extension override record: {key}')
    return raw,{
        'exists':True,
        'sha256':hashlib.sha256(path.read_bytes()).hexdigest(),
        'size_bytes':size,
        'error':None,
    }

def _extension_state_override(raw,key):
    value=raw.get(key) if isinstance(raw,dict) else None
    if not isinstance(value,dict) or 'enabled' not in value:
        return None
    return bool(value.get('enabled'))

def _extension_dependency_values(raw):
    result=[]
    for field in ('depends_on','dependencies','requires'):
        value=raw.get(field) if isinstance(raw,dict) else None
        if isinstance(value,dict):
            values=list(value.keys())
        elif isinstance(value,(list,tuple,set)):
            values=list(value)
        elif isinstance(value,str):
            values=[value]
        else:
            values=[]
        for item in values:
            if isinstance(item,dict):
                item=item.get('key') or item.get('id') or item.get('name')
            item=str(item or '').strip()
            if item and item.casefold() not in {x.casefold() for x in result}:
                result.append(item)
    return result

def _extension_state_catalog():
    raw_state,state_meta=_extension_state_read()
    records=[]
    for record in _inventory_manifest_records():
        path=record.get('manifest_path')
        if not isinstance(path,Path):
            continue
        try:
            rel=path.relative_to(ROOT)
        except Exception:
            continue
        top=rel.parts[0].casefold() if rel.parts else ''
        if top not in {'extensions','modules'}:
            continue
        raw=record.get('raw') if isinstance(record.get('raw'),dict) else {}
        key=str(record.get('key') or '').strip()
        if not key:
            continue
        kind=str(record.get('kind') or 'extension').strip().lower()
        required=bool(raw.get('required') or raw.get('reserved') or kind in {'core','system','department'})
        manifest_default=bool(raw.get('enabled',True))
        override=_extension_state_override(raw_state,key)
        effective=manifest_default if override is None else override
        records.append({
            'key':key,
            'key_fold':key.casefold(),
            'name':str(record.get('name') or key),
            'kind':kind,
            'required':required,
            'manifest_default':manifest_default,
            'override_present':override is not None,
            'override_enabled':override,
            'effective_enabled':effective,
            'dependencies':_extension_dependency_values(raw),
            'manifest_path':path,
            'manifest_sha256':hashlib.sha256(path.read_bytes()).hexdigest() if path.is_file() else None,
            'manifest_valid':not record.get('error') and not record.get('missing_fields'),
            'health_warning':bool(record.get('error') or record.get('missing_fields') or record.get('missing_tools')),
            'raw':raw,
        })
    by_key={}
    for item in records:
        if item['key_fold'] in by_key:
            raise ValueError(f"Duplicate extension key discovered: {item['key']}")
        by_key[item['key_fold']]=item
    for item in records:
        dependents=[]
        for other in records:
            if other is item:
                continue
            if item['key_fold'] in {str(dep).casefold() for dep in other['dependencies']}:
                dependents.append(other['key'])
        item['dependents']=sorted(dependents,key=str.casefold)
        item['eligible']=bool(not item['required'] and item['manifest_valid'])
        item['lock_reason']='' if item['eligible'] else ('Required/core/department extensions cannot be state-overridden.' if item['required'] else 'Manifest validation must pass before state can be changed.')
    return records,by_key,raw_state,state_meta

def _extension_state_find(target):
    target=str(target or '').strip()
    records,by_key,raw_state,state_meta=_extension_state_catalog()
    if not target:
        return None,records,by_key,raw_state,state_meta
    direct=by_key.get(target.casefold())
    if direct:
        return direct,records,by_key,raw_state,state_meta
    inventory=_extension_inventory_snapshot_phase1()
    match=next((item for item in inventory.get('items',[]) if str(item.get('id'))==target),None)
    if match:
        candidates=[
            str(match.get('id') or '').split(':',1)[-1],
            str(match.get('name') or ''),
        ]
        manifest_path=str(match.get('manifest_path') or '').casefold()
        for record in records:
            if manifest_path and str(record['manifest_path']).casefold()==manifest_path:
                return record,records,by_key,raw_state,state_meta
            if record['key_fold'] in {value.casefold() for value in candidates if value}:
                return record,records,by_key,raw_state,state_meta
    return None,records,by_key,raw_state,state_meta

def _extension_state_document_after(raw_state,item,action,proposal_time):
    result=json.loads(json.dumps(raw_state)) if raw_state else {}
    result={key:value for key,value in result.items() if key not in {'schema','updated'}}
    current=result.get(item['key']) if isinstance(result.get(item['key']),dict) else {}
    if action=='restore':
        result.pop(item['key'],None)
    else:
        current=dict(current)
        current['enabled']=action=='enable'
        current['modified']=proposal_time
        current['source']='operator_override'
        current['manifest_default']=item['manifest_default']
        result[item['key']]=current
    overrides=[key for key,value in result.items() if key not in EXTENSION_STATE_RESERVED_KEYS and isinstance(value,dict) and 'enabled' in value]
    if overrides:
        result['_meta']={
            'schema':1,
            'updated':proposal_time,
            'writer':'Extension Manager Phase 2',
            'override_count':len(overrides),
        }
        ordered={'_meta':result['_meta']}
        for key in sorted(overrides,key=str.casefold):
            ordered[key]=result[key]
        return ordered
    return {}

def _extension_state_json_text(document):
    if not document:
        return ''
    return json.dumps(document,indent=2,sort_keys=False)+'\n'

def _extension_state_diff(before,after):
    before_text=_extension_state_json_text(before) if before else '[FILE ABSENT]\n'
    after_text=_extension_state_json_text(after) if after else '[FILE ABSENT]\n'
    import difflib
    return ''.join(difflib.unified_diff(
        before_text.splitlines(keepends=True),
        after_text.splitlines(keepends=True),
        fromfile='Config/extension_state.json (before)',
        tofile='Config/extension_state.json (after)',
    )) or '(no change)'

def _extension_state_effective(item,document):
    override=_extension_state_override(document,item['key'])
    return item['manifest_default'] if override is None else override

def _extension_state_preview_contract(target,action,proposal_time=None):
    action=str(action or '').strip().lower()
    proposal_time=str(proposal_time or now()).strip()
    try:
        proposal_dt=datetime.fromisoformat(proposal_time)
    except Exception:
        return {'ok':False,'message':'Proposal time is invalid. Refresh the preview.'}
    if abs((datetime.now()-proposal_dt).total_seconds())>1800:
        return {'ok':False,'message':'State preview expired after 30 minutes. Refresh the preview.'}
    item,records,by_key,raw_state,state_meta=_extension_state_find(target)
    if action not in EXTENSION_STATE_ACTIONS:
        return {'ok':False,'message':'Action must be enable, disable, or restore.'}
    if not item:
        return {'ok':False,'message':'Optional manifest-backed extension not found.'}
    blockers=[]; warnings=[]
    if not item['eligible']:
        blockers.append(item['lock_reason'] or 'State control is locked.')
    if action=='restore' and not item['override_present']:
        blockers.append('No override exists; the extension already follows its manifest default.')
    proposed=_extension_state_document_after(raw_state,item,action,proposal_time)
    proposed_effective=_extension_state_effective(item,proposed)
    if proposed_effective==item['effective_enabled'] and not (action=='restore' and item['override_present']):
        blockers.append('The requested action would not change the effective state.')
    missing_dependencies=[]; disabled_dependencies=[]
    for dep in item['dependencies']:
        target_dep=by_key.get(str(dep).casefold())
        if not target_dep:
            missing_dependencies.append(dep)
        elif not target_dep['effective_enabled']:
            disabled_dependencies.append(target_dep['key'])
    enabled_dependents=[]
    for dependent_key in item['dependents']:
        dependent=by_key.get(str(dependent_key).casefold())
        if dependent and dependent['effective_enabled']:
            enabled_dependents.append(dependent['key'])
    if proposed_effective:
        if missing_dependencies:
            blockers.append('Missing declared dependencies: '+', '.join(missing_dependencies))
        if disabled_dependencies:
            blockers.append('Disabled declared dependencies: '+', '.join(disabled_dependencies))
    else:
        if enabled_dependents:
            blockers.append('Enabled dependents require this extension: '+', '.join(enabled_dependents))
    if item['health_warning']:
        warnings.append('The manifest or declared tool health needs attention. State changes do not install or repair software.')
    if action=='enable':
        warnings.append('Enabling changes only the FOXAI override; it does not install missing executables or packages.')
    if not proposed_effective:
        warnings.append('Disabling does not terminate an already running process. It blocks Extension Manager launch eligibility and records the state override for state-aware components.')
    state_effect='delete override file' if not proposed and state_meta['exists'] else ('no state file' if not proposed else ('create override file' if not state_meta['exists'] else 'update override file'))
    before_sha=state_meta.get('sha256')
    preview_core={
        'target':item['key'],
        'action':action,
        'proposal_time':proposal_time,
        'manifest_sha256':item['manifest_sha256'],
        'state_before_sha256':before_sha,
        'state_before_exists':state_meta['exists'],
        'proposed_document':proposed,
        'proposed_effective':proposed_effective,
        'blockers':blockers,
    }
    digest=hashlib.sha256(json.dumps(preview_core,sort_keys=True,separators=(',',':')).encode('utf-8')).hexdigest()
    phrase=f"APPROVE EXTENSION STATE {action.upper()} {item['key'].upper()}"
    return {
        'ok':True,
        'target':item['key'],
        'key':item['key'],
        'name':item['name'],
        'action':action,
        'proposal_time':proposal_time,
        'current_effective':item['effective_enabled'],
        'manifest_default':item['manifest_default'],
        'override_present':item['override_present'],
        'override_enabled':item['override_enabled'],
        'proposed_effective':proposed_effective,
        'dependencies':item['dependencies'],
        'dependents':item['dependents'],
        'enabled_dependents':enabled_dependents,
        'warnings':warnings,
        'blockers':blockers,
        'can_apply':not blockers,
        'state_file':str(_extension_state_path()),
        'state_file_exists':state_meta['exists'],
        'state_file_effect':state_effect,
        'diff':_extension_state_diff(raw_state,proposed),
        'preview_digest':digest,
        'approval_phrase':phrase,
        'preview_core':preview_core,
        'configuration_modified':False,
        'read_only':True,
        'message':'Exact state preview ready.' if not blockers else 'Preview created, but the state change is blocked.',
    }

def extension_state_change_preview(d):
    d=d if isinstance(d,dict) else {}
    try:
        result=_extension_state_preview_contract(d.get('target') or d.get('id') or d.get('key'),d.get('action'))
    except Exception as exc:
        return {'ok':False,'message':f'State preview failed closed: {type(exc).__name__}: {exc}','state':'blocked_invalid_state','configuration_modified':False}
    if result.get('ok'):
        result.pop('preview_core',None)
    return result

def _extension_state_write_atomic(path,document):
    path.parent.mkdir(parents=True,exist_ok=True)
    stage=path.with_name(f'.{path.name}.phase2.{os.getpid()}.new')
    try:
        data=_extension_state_json_text(document).encode('utf-8')
        if not data:
            raise ValueError('Atomic writer requires a non-empty state document.')
        if len(data)>EXTENSION_STATE_MAX_BYTES:
            raise ValueError('Proposed extension state exceeds the 64 KB safety limit.')
        with stage.open('wb') as handle:
            handle.write(data); handle.flush(); os.fsync(handle.fileno())
        json.loads(stage.read_text(encoding='utf-8'))
        os.replace(stage,path)
    finally:
        try: stage.unlink(missing_ok=True)
        except Exception: pass

def _extension_state_restore_original(path,before_exists,before_bytes,quarantine=None):
    if quarantine and quarantine.exists():
        if path.exists(): path.unlink()
        os.replace(quarantine,path)
        return
    if before_exists:
        stage=path.with_name(f'.{path.name}.rollback.{os.getpid()}')
        try:
            with stage.open('wb') as handle:
                handle.write(before_bytes); handle.flush(); os.fsync(handle.fileno())
            os.replace(stage,path)
        finally:
            try: stage.unlink(missing_ok=True)
            except Exception: pass
    else:
        path.unlink(missing_ok=True)

def apply_extension_state_change(d):
    d=d if isinstance(d,dict) else {}
    target=d.get('target') or d.get('id') or d.get('key')
    action=str(d.get('action') or '').strip().lower()
    supplied_digest=str(d.get('preview_digest') or '').strip()
    supplied_phrase=str(d.get('approval_phrase') or '').strip()
    with extension_state_lock:
        try:
            preview=_extension_state_preview_contract(target,action,d.get('proposal_time'))
        except Exception as exc:
            return {'ok':False,'message':f'State apply stopped fail-closed before any write: {type(exc).__name__}: {exc}','state':'stopped_fail_closed','verified':True,'configuration_modified':False}
        if not preview.get('ok'):
            return preview
        if not preview.get('can_apply'):
            return {'ok':False,'message':'State change is blocked: '+'; '.join(preview.get('blockers') or [])}
        if supplied_digest!=preview.get('preview_digest'):
            return {'ok':False,'message':'Preview digest mismatch. Refresh the preview; no state was changed.'}
        if supplied_phrase!=preview.get('approval_phrase'):
            return {'ok':False,'message':'Exact approval phrase did not match. No state was changed.'}
        path=_extension_state_path()
        before_exists=path.is_file()
        before_bytes=path.read_bytes() if before_exists else b''
        before_sha=hashlib.sha256(before_bytes).hexdigest() if before_exists else None
        proposed=preview['preview_core']['proposed_document']
        stamp=datetime.now().strftime('%Y%m%dT%H%M%S_%f')
        safe_key=slug(preview['key']).lower() or 'extension'
        backup_root=ROOT/'Backups'/'ExtensionState'/f'{stamp}_{safe_key}_{action}'
        reports_root=ROOT/'Reports'/'ExtensionState'
        backup_path=backup_root/'extension_state.json'
        absent_marker=backup_root/'ABSENT_BEFORE.json'
        try:
            backup_root.mkdir(parents=True,exist_ok=False)
            if before_exists:
                backup_path.write_bytes(before_bytes)
                if hashlib.sha256(backup_path.read_bytes()).hexdigest()!=before_sha:
                    raise ValueError('Backup verification failed.')
            else:
                absent_marker.write_text(json.dumps({'state':'absent_before','verified':True},indent=2),encoding='utf-8')
        except Exception as exc:
            return {'ok':False,'message':f'Backup preparation failed. No state was changed: {exc}','state':'stopped_fail_closed','verified':True,'configuration_modified':False}
        quarantine=None
        rollback_performed=False
        try:
            if proposed:
                _extension_state_write_atomic(path,proposed)
            else:
                if path.exists():
                    quarantine=path.with_name(f'.{path.name}.restore.{os.getpid()}.quarantine')
                    os.replace(path,quarantine)
            after_exists=path.is_file()
            after_document,after_meta=_extension_state_read()
            if after_document!=proposed or after_exists!=bool(proposed):
                raise ValueError('State-file read-back verification failed.')
            item,_,_,current_state,_=_extension_state_find(preview['key'])
            if not item or item['effective_enabled']!=preview['proposed_effective']:
                raise ValueError('Effective extension state verification failed.')
            reports_root.mkdir(parents=True,exist_ok=True)
            receipt_path=reports_root/f'Extension_State_{stamp}_{safe_key}_{action}.json'
            receipt={
                'action':'extension_state_change',
                'created':now(),
                'state':'applied_verified',
                'verified':True,
                'operator_approved':True,
                'extension_key':preview['key'],
                'extension_name':preview['name'],
                'requested_action':action,
                'approval_phrase':preview['approval_phrase'],
                'preview_digest':preview['preview_digest'],
                'manifest_default':preview['manifest_default'],
                'before_effective':preview['current_effective'],
                'after_effective':preview['proposed_effective'],
                'before_override':preview['override_enabled'] if preview['override_present'] else None,
                'after_override':_extension_state_override(current_state,preview['key']),
                'state_file':str(path),
                'state_file_before_exists':before_exists,
                'state_file_after_exists':after_exists,
                'state_file_before_sha256':before_sha,
                'state_file_after_sha256':after_meta.get('sha256'),
                'state_file_effect':preview['state_file_effect'],
                'dependencies':preview['dependencies'],
                'enabled_dependents':preview['enabled_dependents'],
                'backup_path':str(backup_path if before_exists else absent_marker),
                'rollback_performed':False,
                'install_performed':False,
                'remove_performed':False,
                'update_performed':False,
                'download_performed':False,
            }
            receipt_stage=receipt_path.with_name(f'.{receipt_path.name}.{os.getpid()}.new')
            try:
                receipt_stage.write_text(json.dumps(receipt,indent=2),encoding='utf-8')
                os.replace(receipt_stage,receipt_path)
            finally:
                try: receipt_stage.unlink(missing_ok=True)
                except Exception: pass
            verified_receipt=json.loads(receipt_path.read_text(encoding='utf-8'))
            if verified_receipt.get('state')!='applied_verified' or verified_receipt.get('verified') is not True:
                raise ValueError('Receipt verification failed.')
            if quarantine and quarantine.exists():
                quarantine.unlink()
            return {
                'ok':True,
                'message':f"VERIFIED: {preview['name']} now follows the {('enabled' if preview['proposed_effective'] else 'disabled')} effective state.",
                'state':'applied_verified',
                'verified':True,
                'key':preview['key'],
                'enabled':preview['proposed_effective'],
                'state_file':str(path),
                'state_file_exists':path.is_file(),
                'backup_path':str(backup_path if before_exists else absent_marker),
                'receipt_path':str(receipt_path),
                'rollback_performed':False,
            }
        except Exception as exc:
            rollback_performed=True
            try:
                _extension_state_restore_original(path,before_exists,before_bytes,quarantine)
                restored_exists=path.is_file()
                restored_bytes=path.read_bytes() if restored_exists else b''
                restored_ok=(restored_exists==before_exists and restored_bytes==before_bytes)
            except Exception as rollback_exc:
                return {
                    'ok':False,
                    'message':f'Extension state apply failed and rollback also failed: {exc}; rollback: {rollback_exc}',
                    'state':'rollback_failed',
                    'verified':False,
                    'rollback_performed':True,
                }
            return {
                'ok':False,
                'message':f'Extension state apply failed and was rolled back: {exc}',
                'state':'rolled_back_verified' if restored_ok else 'rollback_failed',
                'verified':bool(restored_ok),
                'rollback_performed':True,
            }

def _extension_state_control_map():
    records,_,_,meta=_extension_state_catalog()
    return {item['key_fold']:{
        'key':item['key'],
        'eligible':item['eligible'],
        'lock_reason':item['lock_reason'],
        'manifest_default':item['manifest_default'],
        'override_present':item['override_present'],
        'override_enabled':item['override_enabled'],
        'effective_enabled':item['effective_enabled'],
        'dependencies':item['dependencies'],
        'dependents':item['dependents'],
        'state_file_exists':meta['exists'],
        'manifest_path':str(item['manifest_path']),
    } for item in records}

def extension_inventory_snapshot():
    data=_extension_inventory_snapshot_phase1()
    try:
        controls=_extension_state_control_map()
        state_raw,state_meta=_extension_state_read()
        override_count=sum(1 for key,value in state_raw.items() if key not in EXTENSION_STATE_RESERVED_KEYS and isinstance(value,dict) and 'enabled' in value)
        for item in data.get('items',[]):
            candidates=[
                str(item.get('id') or '').split(':',1)[-1].casefold(),
                str(item.get('name') or '').casefold(),
            ]
            manifest_path=str(item.get('manifest_path') or '').casefold()
            control=None
            for key,value in controls.items():
                if key in candidates:
                    control=value; break
                record_path=str(value.get('manifest_path') or '').casefold()
                if manifest_path and record_path==manifest_path:
                    control=value; break
            if control:
                item['state_control']=control
        data['read_only']=True
        data['report_only']=True
        data['guarded_state_write_available']=True
        data['configuration_modified']=False
        data['state_file_created']=False
        data['summary']['state_controls']=sum(1 for value in controls.values() if value['eligible'])
        data['summary']['state_overrides']=override_count
        data['summary']['state_enabled']=sum(1 for value in controls.values() if value['effective_enabled'])
        data['summary']['state_disabled']=sum(1 for value in controls.values() if not value['effective_enabled'])
        data['sources']['extension_state']={
            'path':str(_extension_state_path()),
            'exists':state_meta['exists'],
            'overrides':override_count,
            'mode':'guarded explicit overrides' if state_meta['exists'] else 'manifest defaults; no state file created',
        }
        data['safety'].update({
            'configuration_write':'optional extension state only; exact preview + typed approval + digest + backup + receipt + rollback',
            'required_state_change':False,
            'install':False,
            'remove':False,
            'update':False,
            'download':False,
        })
        data['message']=f"Inventory: {data['summary']['total']} component(s), {data['summary']['state_controls']} guarded state control(s), {override_count} override(s)."
    except Exception as exc:
        data['state_control_error']=f'{type(exc).__name__}: {exc}'
        data['summary']['state_controls']=0
        data['summary']['state_overrides']=0
        data['sources']['extension_state']={
            'path':str(_extension_state_path()),
            'exists':_extension_state_path().is_file(),
            'mode':'fail-closed: state controls unavailable',
            'error':str(exc),
        }
    return data

def launch_extension_inventory_item(d):
    item=_inventory_lookup(d.get('id') if isinstance(d,dict) else '')
    control=(item or {}).get('state_control') or {}
    if control and not control.get('effective_enabled'):
        return {
            'ok':False,
            'message':f"{item.get('name') or 'Extension'} is disabled by an approved extension-state override. Restore or enable it through the guarded preview before launch.",
            'state':'blocked_extension_disabled',
            'configuration_modified':False,
        }
    return _launch_extension_inventory_item_phase1(d)
# EXTENSION_MANAGER_SAFE_STATE_PHASE2_BACKEND_END


def extension_roots():
    roots=[FOLDERS.get('extensions',ROOT/'Extensions'),FOLDERS.get('modules',ROOT/'Modules'),ROOT/'Departments']
    for r in roots:
        try: r.mkdir(parents=True,exist_ok=True)
        except Exception: pass
    return roots

def extension_state_file():
    p=FOLDERS.get('config',ROOT/'Config')/'extension_state.json'
    p.parent.mkdir(parents=True,exist_ok=True)
    return p

def read_extension_state():
    return jread(extension_state_file(),{})

def write_extension_state(d):
    jwrite(extension_state_file(),d)

def manifest_candidates():
    files=[]
    for root in extension_roots():
        if not root.exists(): continue
        for name in ['manifest.json','module.json','extension.json']:
            files.extend(root.glob(f'*/{name}'))
        # Allow direct loose manifests in Extensions for early testing.
        if root.name.lower() in ['extensions','modules']:
            for name in ['manifest.json','module.json','extension.json']:
                p=root/name
                if p.exists(): files.append(p)
    # Deduplicate while preserving order.
    seen=set(); out=[]
    for p in files:
        s=str(p.resolve()).lower()
        if s not in seen:
            seen.add(s); out.append(p)
    return out

def extension_key_from_path(p):
    try:
        rel=str(p.parent.relative_to(ROOT)).replace('\\','/')
    except Exception:
        rel=p.parent.name
    return slug(rel).lower()

def normalize_extension_manifest(p):
    d=jread(p,{})
    key=d.get('id') or d.get('key') or d.get('name') or extension_key_from_path(p)
    name=d.get('name') or d.get('title') or p.parent.name
    version=d.get('version') or '0.0.0'
    desc=d.get('description') or d.get('summary') or ''
    kind=d.get('type') or d.get('kind') or ('department' if 'Departments' in str(p) else 'extension')
    officer=d.get('officer') or d.get('lead') or d.get('captain') or ''
    required=['name','version']
    missing=[x for x in required if not d.get(x)]
    state=read_extension_state()
    enabled=state.get(key,{}).get('enabled',d.get('enabled',True))
    status='VALID' if not missing else 'CHECK'
    return {
        'key':key,
        'name':name,
        'version':version,
        'description':desc,
        'kind':kind,
        'officer':officer,
        'enabled':bool(enabled),
        'status':status,
        'missing':missing,
        'manifest':str(p),
        'folder':str(p.parent),
        'raw':d
    }

def list_extensions():
    items=[normalize_extension_manifest(p) for p in manifest_candidates()]
    # Built-in shell entry so the page is never empty.
    if not any(x.get('key')=='extension-manager' for x in items):
        items.insert(0,{
            'key':'extension-manager',
            'name':'Extension Manager',
            'version':'0.1-shell',
            'description':'Built-in Kayock module manager shell.',
            'kind':'system',
            'officer':'Kayock Command OS',
            'enabled':True,
            'status':'VALID',
            'missing':[],
            'manifest':'built-in',
            'folder':str(FOLDERS.get('extensions',ROOT/'Extensions')),
            'raw':{}
        })
    valid=sum(1 for x in items if x.get('status')=='VALID')
    enabled=sum(1 for x in items if x.get('enabled'))
    state_path=extension_state_file()
    return {'ok':True,'count':len(items),'valid':valid,'enabled':enabled,'state_file':str(state_path),'state_file_exists':state_path.is_file(),'items':items}

def toggle_extension(d):
    return {
        'ok':False,
        'message':'Direct extension toggles are disabled. Use the Phase 2 exact preview and typed approval flow.',
        'state':'blocked_safe_preview_required',
        'configuration_modified':False,
    }

def validate_extensions():
    data=list_extensions()
    problems=[]
    for item in data.get('items',[]):
        if item.get('missing'):
            problems.append({'key':item.get('key'),'name':item.get('name'),'missing':item.get('missing'),'manifest':item.get('manifest')})
    return {'ok':True,'checked':data.get('count',0),'valid':data.get('valid',0),'problems':problems,'message':f"Checked {data.get('count',0)} extension manifest(s); {len(problems)} problem(s)."}

def create_sample_extension():
    root=FOLDERS.get('extensions',ROOT/'Extensions')/'SampleExtension'
    root.mkdir(parents=True,exist_ok=True)
    p=root/'manifest.json'
    if not p.exists():
        jwrite(p,{
            'id':'sample-extension',
            'name':'Sample Extension',
            'version':'0.1.0',
            'type':'extension',
            'description':'Example Kayock extension manifest for future .kmod packages.',
            'officer':'Sample Officer',
            'enabled':False,
            'entry':'README.md',
            'permissions':['read-only']
        })
        (root/'README.md').write_text('# Sample Extension\n\nThis is a placeholder extension manifest for Kayock Command OS.\n',encoding='utf-8')
    return {'ok':True,'message':'Sample extension manifest ready.','folder':str(root),'manifest':str(p)}


def extension_report_export():
    reports=FOLDERS.get('reports',ROOT/'Reports')
    reports.mkdir(parents=True,exist_ok=True)
    stamp=datetime.now().strftime('%Y%m%d_%H%M%S')
    data=list_extensions()
    validation=validate_extensions()
    report={
        'ok':True,
        'created':now(),
        'title':'Kayock Extension Report',
        'summary':{
            'count':data.get('count',0),
            'enabled':data.get('enabled',0),
            'valid':data.get('valid',0),
            'problems':len(validation.get('problems',[])),
        },
        'state_file':data.get('state_file',''),
        'items':data.get('items',[]),
        'problems':validation.get('problems',[])
    }
    json_path=reports/f'Extension_Report_{stamp}.json'
    md_path=reports/f'Extension_Report_{stamp}.md'
    jwrite(json_path,report)
    lines=[
        '# Kayock Extension Report',
        '',
        f"Created: {report['created']}",
        '',
        '## Summary',
        '',
        f"- Modules: {report['summary']['count']}",
        f"- Enabled: {report['summary']['enabled']}",
        f"- Valid: {report['summary']['valid']}",
        f"- Problems: {report['summary']['problems']}",
        f"- State file: {report['state_file']}",
        '',
        '## Problems',
        ''
    ]
    if report['problems']:
        for p in report['problems']:
            lines += [
                f"### {p.get('name') or p.get('key')}",
                '',
                f"- Key: {p.get('key','')}",
                f"- Missing: {', '.join(p.get('missing',[]))}",
                f"- Manifest: {p.get('manifest','')}",
                ''
            ]
    else:
        lines += ['No manifest problems found.','']
    lines += ['## Modules','']
    for x in report['items']:
        lines += [
            f"### {x.get('name','Unnamed Module')}",
            '',
            f"- Key: {x.get('key','')}",
            f"- Version: {x.get('version','')}",
            f"- Kind: {x.get('kind','')}",
            f"- Status: {x.get('status','')}",
            f"- Enabled: {x.get('enabled')}",
            f"- Missing: {', '.join(x.get('missing',[])) if x.get('missing') else 'None'}",
            f"- Manifest: {x.get('manifest','')}",
            f"- Folder: {x.get('folder','')}",
            '',
            x.get('description','') or '',
            ''
        ]
    md_path.write_text('\n'.join(lines),encoding='utf-8')
    if active_project:
        timeline(active_project,f'Exported extension report: {md_path.name}')
    return {'ok':True,'message':'Extension report exported.','json':str(json_path),'markdown':str(md_path),'folder':str(reports),'summary':report['summary']}

def suggest_manifest_repair(d):
    manifest=d.get('manifest') or ''
    key=d.get('key') or ''
    target=None
    if manifest and manifest!='built-in':
        p=Path(manifest)
        if p.exists():
            target=p
    if target is None and key:
        for p in manifest_candidates():
            item=normalize_extension_manifest(p)
            if item.get('key')==key:
                target=p
                break
    if target is None:
        return {'ok':False,'message':'Could not find a manifest file for repair suggestion.'}

    raw=jread(target,{})
    folder_name=target.parent.name
    suggested=dict(raw)
    if not suggested.get('id'):
        suggested['id']=slug(folder_name).lower()
    if not suggested.get('name'):
        suggested['name']=folder_name.replace('_',' ').replace('-',' ').title()
    if not suggested.get('version'):
        suggested['version']='0.1.0'
    if not suggested.get('type') and not suggested.get('kind'):
        suggested['type']='department' if 'Departments' in str(target) else 'extension'
    if not suggested.get('description'):
        suggested['description']=f"{suggested.get('name','Module')} module for Kayock Command OS."
    if 'enabled' not in suggested:
        suggested['enabled']=True
    repaired=json.dumps(suggested,indent=2,ensure_ascii=False)
    return {
        'ok':True,
        'message':'Manifest repair suggestion generated.',
        'manifest':str(target),
        'folder':str(target.parent),
        'original':json.dumps(raw,indent=2,ensure_ascii=False),
        'suggested':repaired
    }


def apply_manifest_repair(d):
    manifest=d.get('manifest') or ''
    suggested_text=d.get('suggested') or ''
    key=d.get('key') or ''
    target=None

    if manifest and manifest!='built-in':
        p=Path(manifest)
        if p.exists():
            target=p

    if target is None and key:
        for p in manifest_candidates():
            item=normalize_extension_manifest(p)
            if item.get('key')==key:
                target=p
                break

    if target is None:
        return {'ok':False,'message':'Could not find manifest file to repair.'}

    if not suggested_text.strip():
        suggestion=suggest_manifest_repair({'manifest':str(target),'key':key})
        if not suggestion.get('ok'):
            return suggestion
        suggested_text=suggestion.get('suggested','')

    try:
        suggested_json=json.loads(suggested_text)
    except Exception as e:
        return {'ok':False,'message':f'Suggested manifest is not valid JSON: {e}'}

    before=normalize_extension_manifest(target)
    backup_dir=FOLDERS.get('manifest_backups',ROOT/'Backups'/'Manifests')
    backup_dir.mkdir(parents=True,exist_ok=True)
    stamp=datetime.now().strftime('%Y%m%d_%H%M%S')
    backup_path=backup_dir/f"{slug(target.parent.name)}_manifest_{stamp}.json"

    try:
        shutil.copy2(target,backup_path)
    except Exception as e:
        return {'ok':False,'message':f'Could not back up manifest before repair: {e}'}

    try:
        jwrite(target,suggested_json)
    except Exception as e:
        try:
            shutil.copy2(backup_path,target)
        except Exception:
            pass
        return {'ok':False,'message':f'Could not write repaired manifest. Original was restored if possible. Error: {e}','backup':str(backup_path)}

    after=normalize_extension_manifest(target)
    validation=validate_extensions()
    if active_project:
        timeline(active_project,f'Applied safe manifest repair: {target.name} backed up to {backup_path.name}')

    return {
        'ok':True,
        'message':'Manifest repair applied safely.',
        'manifest':str(target),
        'backup':str(backup_path),
        'before':{
            'status':before.get('status'),
            'missing':before.get('missing',[]),
            'version':before.get('version')
        },
        'after':{
            'status':after.get('status'),
            'missing':after.get('missing',[]),
            'version':after.get('version')
        },
        'validation':validation
    }



def repair_bay_prepare_handoff(d=None):
    request=d or {}
    finding_id=str(request.get('finding_id') or '').strip()
    level=str(request.get('level') or 'guided').strip().lower()
    mode=str(request.get('mode') or 'full').strip().lower()
    full_only={'full_python_syntax','configuration_json','zero_byte_live_files','log_growth','root_launcher_inventory'}
    if finding_id in full_only:
        mode='full'
    if mode not in {'quick','full'}:
        mode='full'
    try:
        from core.repair_bay_diagnostics import run_repair_bay_scan
        from core.repair_bay_handoff import build_repair_handoff
        report=run_repair_bay_scan(
            ROOT,
            mode=mode,
            context={
                'interface':'WebUI',
                'active_project':active_project or '',
                'operator':'local',
                'purpose':'guarded_repair_handoff',
            },
        )
        scan_safety=report.get('safety') or {}
        if not report.get('read_only') or bool(scan_safety.get('network_used')) or bool(scan_safety.get('commands_run')) or int(scan_safety.get('files_written') or 0)!=0 or int(scan_safety.get('repairs_applied') or 0)!=0:
            return {'ok':False,'message':'Guarded handoff blocked because the grounding scan did not verify read-only safety.','read_only':True,'changes_applied':0,'mission_staged':False}
        packet=build_repair_handoff(ROOT,report,finding_id,level=level)
        safety=packet.get('safety_limits') or {}
        checks=[
            {'id':'read_only','ok':bool(packet.get('read_only')),'message':'Handoff preparation was read-only.'},
            {'id':'no_changes','ok':int(packet.get('changes_applied') or 0)==0,'message':'No repair or project change was applied.'},
            {'id':'mission_not_staged','ok':not bool(packet.get('mission_staged')),'message':'Mission Console review is required before staging.'},
            {'id':'implementation_not_authorized','ok':not bool(packet.get('implementation_authorized')),'message':'The handoff does not authorize implementation.'},
            {'id':'no_network','ok':not bool(safety.get('network_allowed')),'message':'The proposed planning mission forbids network use.'},
            {'id':'no_auto_apply','ok':not bool(safety.get('automatic_apply_allowed')),'message':'Automatic application is forbidden.'},
        ]
        verified=bool(packet.get('ok')) and all(item['ok'] for item in checks)
        packet['receipt']=make_tool_receipt(
            'repair_bay.guarded_handoff',
            'verified' if verified else 'blocked',
            checks=checks,
            details={
                'finding_id':(packet.get('finding') or {}).get('id'),
                'eligible':bool(packet.get('eligible')),
                'repair_kind':packet.get('repair_kind'),
                'affected_paths':len(packet.get('affected_paths') or []),
                'implementation_authorized':False,
            },
            actor='operator',
        )
        packet['claim_state']='verified' if verified else 'blocked'
        return packet
    except Exception as exc:
        return {
            'ok':False,
            'message':f'Guarded repair handoff failed closed: {type(exc).__name__}: {exc}',
            'read_only':True,
            'changes_applied':0,
            'mission_staged':False,
            'implementation_authorized':False,
        }



# REPAIR_BAY_SYSTEM_BASELINE_V3_SERVER_START
def repair_bay_system_baseline(route,d=None):
    try:
        from core.repair_bay_baseline import api_dispatch
        result=api_dispatch(ROOT,route,d or {})
        if isinstance(result,dict):
            result.setdefault('read_only_system',True)
            result.setdefault('network_used',False)
            result.setdefault('repair_actions_applied',0)
        return result
    except Exception as exc:
        return {
            'ok':False,
            'message':f'System Baseline failed closed: {type(exc).__name__}: {exc}',
            'read_only_system':True,
            'network_used':False,
            'repair_actions_applied':0,
        }
