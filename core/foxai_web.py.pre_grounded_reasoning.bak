        if(q('nfExportStatus'))q('nfExportStatus').innerHTML=`${esc(d.message)}
Markdown: ${esc(d.markdown)}
Text: ${esc(d.text)}
JSON: ${esc(d.json)}

<button onclick="sendExportedBiblePath('${js(d.markdown)}')">Send Markdown Path to Mission Console</button>`;
