        if path=='/api/extensions/apply_repair': self.js(apply_manifest_repair(d)); return
        if path=='/api/extensions/repair_suggest': self.js(suggest_manifest_repair(d)); return
        if path=='/api/extensions/toggle': self.js(toggle_extension(d)); return
        if path=='/api/novelforge/export': self.js(export_story_bible(d)); return
        if path=='/api/novelforge/save': self.js(save_universe(d)); return
        if path=='/api/novelforge/duplicate': self.js(duplicate_universe(d)); return
        if path=='/api/novelforge/rename': self.js(rename_universe(d)); return
        if path=='/api/novelforge/delete': self.js(delete_universe(d.get('name',''))); return
        if path=='/api/prompts/save': self.js(save_prompt(d)); return
        if path=='/api/prompts/import': self.js(save_prompt(dict(d, source='PromptSmith Extension Import'))); return
        if path=='/api/prompts/duplicate': self.js(duplicate_prompt(d)); return
        if path=='/api/prompts/rename': self.js(rename_prompt(d)); return
        if path=='/api/prompts/delete': self.js(delete_prompt(d.get('name',''))); return
        if path=='/api/memory/save': self.js(save_state('Mission state manually saved')); return
        if path=='/api/memory/task/add':
            if not active_project: self.js({'ok':False,'message':'Select a project first.'}); return
            t=tasks(); txt=d.get('text','').strip(); t.append({'text':txt,'done':False,'created':now()}); save_tasks(t); timeline(active_project,f'Task added: {txt}'); self.js({'ok':True,'message':'Task added.'}); return
        if path=='/api/memory/task/toggle':
            if not active_project: self.js({'ok':False,'message':'Select a project first.'}); return
            t=tasks(); i=int(d.get('index',-1));
            if i<0 or i>=len(t): self.js({'ok':False,'message':'Task not found.'}); return
            t[i]['done']=bool(d.get('done')); t[i]['updated']=now(); save_tasks(t); timeline(active_project,('Task completed: ' if t[i]['done'] else 'Task reopened: ')+t[i]['text']); self.js({'ok':True,'message':'Task updated.'}); return
        if path=='/api/projects/create': self.js(create_project(d.get('name',''))); return
        if path=='/api/projects/select': self.js(select_project(d.get('name',''))); return
        if path=='/api/projects/save-note': self.js(save_note(d.get('name',''),d.get('note',''))); return
        if path=='/api/professor/set': self.js(set_prof(d.get('key',''))); return
        if path=='/api/chat/image/clear':
            clear_result=clear_active_mission_image()
            messages[:]=compact_prior_images(messages)
            self.js(clear_result); return
        if path=='/api/model-sources/choose-folder': self.js(model_source_choose_folder()); return
        if path=='/api/model-sources/approve-folder': self.js(model_source_approve_folder(d)); return
        if path=='/api/model-sources/forget-folder': self.js(model_source_forget_folder(d)); return
        if path=='/api/model-sources/forget-model': self.js(model_source_forget_model(d)); return
        if path=='/api/model-sources/forget-machine': self.js(model_source_forget_machine(d)); return
        if path=='/api/chat/start': self.js(start_chat(d.get('model',''),d.get('profile',''))); return
        # GUARDED_STREAMING_PHASE2_ROUTE_START
        if path=='/api/chat/stream':
            text=(d.get('message') or '').strip()
            use_active=bool(d.get('use_active_image'))
            try:
                image=validate_mission_image(d.get('image'))
            except MissionRequestError as exc:
                self.send_response(exc.status)
                self.send_header('Content-Type','application/json; charset=utf-8')
                self.send_header('Cache-Control','no-store')
                self.end_headers()
                self.wfile.write(json.dumps({'ok':False,'message':str(exc)}).encode('utf-8'))
                return
            if not text and not image and not use_active:
                self.js({'ok':False,'message':'Empty message.'})
                return
            text=text or 'Describe this image.'
            profile=active_chat_profile()
            if (image or use_active) and not bool(profile.get('vision')):
                self.send_response(409)
                self.send_header('Content-Type','application/json; charset=utf-8')
                self.send_header('Cache-Control','no-store')
                self.end_headers()
                self.wfile.write(json.dumps({'ok':False,'message':'A verified Fast Vision or Quality Vision profile must be explicitly active. No model switch occurred.'}).encode('utf-8'))
                return
            if (image or use_active) and is_explicit_engineer_command(text):
                self.send_response(409)
                self.send_header('Content-Type','application/json; charset=utf-8')
                self.send_header('Cache-Control','no-store')
                self.end_headers()
                self.wfile.write(json.dumps({'ok':False,'message':'Engineer image inspection is not enabled.','fallback':None}).encode('utf-8'))
                return
            if is_explicit_engineer_command(text):
                self.send_response(409)
                self.send_header('Content-Type','application/json; charset=utf-8')
                self.send_header('Cache-Control','no-store')
                self.end_headers()
                self.wfile.write(json.dumps({
                    'ok':False,
                    'message':'Engineer commands use the verified non-streaming route.',
                    'fallback':'/api/chat/send',
                }).encode('utf-8'))
                return
            if not web_chat_stream_lock.acquire(blocking=False):
                self.send_response(409)
                self.send_header('Content-Type','application/json; charset=utf-8')
                self.send_header('Cache-Control','no-store')
                self.end_headers()
                self.wfile.write(json.dumps({
                    'ok':False,
                    'message':'Another guarded chat turn is already running.',
                }).encode('utf-8'))
                return

            request_started=time.perf_counter()
            stream_started=False
            client_disconnected=False
            try:
                session_receipt=ensure_web_mission_session()
                context=prepare_mission_image_context(messages,text,image,use_active)
                effective_image=context['image']
                route_receipt=make_tool_receipt(
                    'webui.department_route',
                    'verified',
                    checks=[
                        {'id':'explicit_engineer_command_absent','ok':True,'message':'Guarded streaming is limited to ordinary Agent Fox chat.'},
                        {'id':'agent_fox_privilege_boundary','ok':True,'message':'Model text cannot invoke Engineer or Repair Chamber.'},
                    ],
                    details={'route':'agent_fox','professor':active_prof()[0],'transport':'guarded_sentence_ndjson','profile_id':chat_profile_id,'image':mission_image_receipt_details(effective_image),'image_source':context['source']},
                    actor='operator',
                )

                health_started=time.perf_counter()
                chat_online=check(CHAT_HEALTH)
                health_ms=round((time.perf_counter()-health_started)*1000,1)
                if not chat_online:
                    answer='Chat engine is offline. Start Chat Engine first.'
                    web_mission_session.add('ERIC',context['history_user_message']['content'])
                    web_mission_session.add('SYSTEM',answer)
                    archive_started=time.perf_counter()
                    archive_receipt=web_mission_session.save()
                    archive_ms=round((time.perf_counter()-archive_started)*1000,1)
                    self.start_ndjson();stream_started=True
                    self.ndjson({
                        'type':'error','ok':False,'answer':answer,'speaker':'SYSTEM',
                        'message':answer,'route':'agent_fox','route_receipt':route_receipt,
                        'archive_receipt':archive_receipt,'session_receipt':session_receipt,
                        'timing':{
                            'health_ms':health_ms,'model_ms':0.0,'first_guarded_chunk_ms':0.0,
                            'guard_ms':0.0,'archive_ms':archive_ms,'state_save_ms':0.0,
                            'receipt_ms':0.0,'stream_chunks':0,
                            'server_total_ms':round((time.perf_counter()-request_started)*1000,1),
                        },
                    })
                    return

                user_message=context['history_user_message']
                request_messages=context['request_messages']
                speaker=active_prof()[0].upper()
                self.start_ndjson();stream_started=True
                self.ndjson({
                    'type':'start','ok':True,'speaker':speaker,'route':'agent_fox',
                    'guarded':True,'provisional':True,
                    'message':'Complete sentence/newline chunks are claim-guarded before display.',
                })

                model_started=time.perf_counter()
                raw_answer='';pending='';stream_chunks=0;first_guarded_chunk_ms=0.0
                chunk_guard_ms=0.0;chunk_flagged=False
                payload={'model':'local-model','messages':request_messages,'temperature':0.7,'max_tokens':768,'stream':True}
                for token in iter_chat_stream(payload):
                    raw_answer+=token;pending+=token
                    units,pending=guarded_stream_units(pending,final=False)
                    for unit in units:
                        guard_started=time.perf_counter()
                        guarded=guarded_stream_piece(unit)
                        chunk_guard_ms+=round((time.perf_counter()-guard_started)*1000,1)
                        chunk_flagged=chunk_flagged or bool(guarded.get('flagged'))
                        if guarded.get('text'):
                            stream_chunks+=1
                            if not first_guarded_chunk_ms:
                                first_guarded_chunk_ms=round((time.perf_counter()-model_started)*1000,1)
                            self.ndjson({
                                'type':'chunk','ok':True,'speaker':speaker,
                                'text':guarded['text'],'guarded':True,'provisional':True,
                                'claim_flagged':bool(guarded.get('flagged')),
                            })

                units,pending=guarded_stream_units(pending,final=True)
                for unit in units:
                    guard_started=time.perf_counter()
                    guarded=guarded_stream_piece(unit)
                    chunk_guard_ms+=round((time.perf_counter()-guard_started)*1000,1)
                    chunk_flagged=chunk_flagged or bool(guarded.get('flagged'))
                    if guarded.get('text'):
                        stream_chunks+=1
                        if not first_guarded_chunk_ms:
                            first_guarded_chunk_ms=round((time.perf_counter()-model_started)*1000,1)
                        self.ndjson({
                            'type':'chunk','ok':True,'speaker':speaker,
                            'text':guarded['text'],'guarded':True,'provisional':True,
                            'claim_flagged':bool(guarded.get('flagged')),
                        })

                model_ms=round((time.perf_counter()-model_started)*1000,1)
                raw_ans=raw_answer.strip()
                if not raw_ans:
                    raise RuntimeError('Chat engine returned an empty streamed response.')

                guard_started=time.perf_counter()
                claim_guard=guard_model_action_claims(raw_ans)
                ans=claim_guard['text']
                final_guard_ms=round((time.perf_counter()-guard_started)*1000,1)
                guard_ms=round(chunk_guard_ms+final_guard_ms,1)

                messages[:]=compact_prior_images(messages)
                messages.append(user_message)
                messages.append({'role':'assistant','content':ans})
                timeline(active_project,'Image context used in Mission Console' if effective_image else 'Message sent to Mission Console') if active_project else None
                web_mission_session.add('ERIC',user_message['content'])
                web_mission_session.add(speaker,ans)

                archive_started=time.perf_counter()
                archive_receipt=web_mission_session.save()
                archive_ms=round((time.perf_counter()-archive_started)*1000,1)

                state_started=time.perf_counter()
                save_state('Agent response received')
                state_save_ms=round((time.perf_counter()-state_started)*1000,1)

                receipt_started=time.perf_counter()
                completion_receipt=make_tool_receipt(
                    'chat_completion',
                    'verified',
                    checks=[
                        {'id':'chat_api_stream_completed','ok':True,'message':'Local chat API completed its stream.'},
                        {'id':'raw_tokens_not_exposed','ok':True,'message':'Only complete guarded units were sent to the browser.'},
                        {'id':'final_full_answer_guarded','ok':True,'message':'The complete answer was claim-guarded before archive and final display.'},
                        {'id':'image_attachment_verified','ok':True,'message':'Image bytes and metadata were verified before model submission.' if effective_image else 'No image context was supplied.'},
                        {'id':'image_data_not_archived','ok':True,'message':'Mission Archive stores image metadata and SHA-256, never the base64 image payload.'},
                    ],
                    details={
                        'external_action_verified':False,
                        'profile_id':chat_profile_id,
                        'image':mission_image_receipt_details(effective_image),
                        'image_source':context['source'],
                        'claim_flagged':bool(claim_guard.get('flagged') or chunk_flagged),
                        'transport':'guarded_sentence_ndjson',
                        'stream_chunks':stream_chunks,
                    },
                    actor='mission_console',
                )
                receipt_ms=round((time.perf_counter()-receipt_started)*1000,1)

                timing={
                    'health_ms':health_ms,
                    'model_ms':model_ms,
                    'first_guarded_chunk_ms':first_guarded_chunk_ms,
                    'guard_ms':guard_ms,
                    'archive_ms':archive_ms,
                    'state_save_ms':state_save_ms,
                    'receipt_ms':receipt_ms,
                    'stream_chunks':stream_chunks,
                    'server_total_ms':round((time.perf_counter()-request_started)*1000,1),
                }
                archived=bool(archive_receipt.get('verified'))
                self.ndjson({
                    'type':'final','ok':archived,'answer':ans,'speaker':speaker,
                    'message':'Agent response returned but archive verification failed.' if not archived else 'Agent response archived.',
                    'route':'agent_fox','guarded':True,'provisional':False,
                    'claim_guard':claim_guard,'route_receipt':route_receipt,
                    'completion_receipt':completion_receipt,'archive_receipt':archive_receipt,
                    'session_receipt':session_receipt,'timing':timing,
                    'active_image':context['active_image'],
                })
                return
            except (BrokenPipeError,ConnectionAbortedError,ConnectionResetError):
                client_disconnected=True
                return
            except Exception as e:
                if client_disconnected:
                    return
                answer=f'Chat request failed: {e}'
                web_mission_session.add('ERIC',text)
                web_mission_session.add('SYSTEM',answer)
                archive_started=time.perf_counter()
                archive_receipt=web_mission_session.save()
                archive_ms=round((time.perf_counter()-archive_started)*1000,1)
                timing={
                    'health_ms':locals().get('health_ms',0.0),
                    'model_ms':round((time.perf_counter()-model_started)*1000,1) if 'model_started' in locals() else 0.0,
                    'first_guarded_chunk_ms':locals().get('first_guarded_chunk_ms',0.0),
                    'guard_ms':locals().get('chunk_guard_ms',0.0),
                    'archive_ms':archive_ms,
                    'state_save_ms':0.0,
                    'receipt_ms':0.0,
                    'stream_chunks':locals().get('stream_chunks',0),
                    'server_total_ms':round((time.perf_counter()-request_started)*1000,1),
                }
                try:
                    if not stream_started:
                        self.start_ndjson();stream_started=True
                    self.ndjson({
                        'type':'error','ok':False,'answer':answer,'speaker':'SYSTEM',
                        'message':answer,'route':'agent_fox',
                        'archive_receipt':archive_receipt,
                        'session_receipt':locals().get('session_receipt'),
                        'timing':timing,
                    })
                except (BrokenPipeError,ConnectionAbortedError,ConnectionResetError):
                    pass
                return
            finally:
                web_chat_stream_lock.release()
        # GUARDED_STREAMING_PHASE2_ROUTE_END
        if path=='/api/chat/send':
            text=(d.get('message') or '').strip()
            use_active=bool(d.get('use_active_image'))
            try:
                image=validate_mission_image(d.get('image'))
            except MissionRequestError as exc:
                self.send_response(exc.status)
                self.send_header('Content-Type','application/json; charset=utf-8')
                self.send_header('Cache-Control','no-store')
                self.end_headers()
                self.wfile.write(json.dumps({'ok':False,'message':str(exc)}).encode('utf-8'))
                return
            if not text and not image and not use_active:
                self.js({'ok':False,'message':'Empty message.'})
                return
            text=text or 'Describe this image.'
            profile=active_chat_profile()
            if (image or use_active) and not bool(profile.get('vision')):
                self.js({'ok':False,'message':'A verified Fast Vision or Quality Vision profile must be explicitly active. No model switch occurred.'});return
            if (image or use_active) and is_explicit_engineer_command(text):
                self.js({'ok':False,'message':'Engineer image inspection is not enabled.'});return

            session_receipt=ensure_web_mission_session()
            context=prepare_mission_image_context(messages,text,image,use_active)
            effective_image=context['image']
            web_mission_session.add('ERIC',context['history_user_message']['content'])
            explicit_engineer=is_explicit_engineer_command(text)

            if explicit_engineer:
                mission_id=web_mission_session.session_id or ''
                correlation_id=new_airlock_correlation_id()
                route=direct_mission(
                    text,
                    actor='operator',
                    operator_approved=True,
                    correlation_id=correlation_id,
                    mission_id=mission_id,
                    audit=False,
                )
                correlation_id=route.get('correlation_id') or correlation_id
                engineer_selected=route.get('agent')=='engineer'
                route_receipt=make_tool_receipt(
                    'webui.department_route',
                    'verified' if engineer_selected else 'denied',
                    checks=[
                        {'id':'explicit_engineer_command','ok':True,'message':'The operator used an explicit Engineer command.'},
                        {'id':'director_selected_engineer','ok':engineer_selected,'message':'Director selected Engineer.' if engineer_selected else 'Director did not select Engineer.'},
                    ],
                    details={
                        'route':route.get('agent'),
                        'owner_use':True,
                        'read_only_default':True,
                        'security_containment':False,
                    },
                    actor='operator',
                    correlation_id=correlation_id,
                    mission_id=mission_id,
                )
                if not engineer_selected:
                    answer='Engineer route was not selected.'
                    web_mission_session.add('SYSTEM',answer)
                    archive_receipt=web_mission_session.save()
                    self.js({
                        'ok':False,
                        'answer':answer,
                        'speaker':'SYSTEM',
                        'message':answer,
                        'route_receipt':route_receipt,
                        'archive_receipt':archive_receipt,
                        'session_receipt':session_receipt,
                        'correlation_id':correlation_id,
                    })
                    return
                try:
                    answer=web_engineer_analyze(
                        route.get('payload') or text,
                        mission_id=mission_id,
                        correlation_id=correlation_id,
                        caller='operator',
                    )
                    web_mission_session.add('ENGINEER',answer)
                    archive_receipt=web_mission_session.save()
                    completion_receipt=make_tool_receipt(
                        'engineer.inspect',
                        'verified',
                        checks=[
                            {'id':'engineer_response_present','ok':bool(answer.strip()),'message':'Engineer returned an analysis response.'},
                            {'id':'workshop_apply_boundary_preserved','ok':True,'message':'Project writes remain behind Workshop preview, exact apply confirmation, snapshot, validation, receipt, and rollback.'},
                        ],
                        details={
                            'interface':'WebUI',
                            'read_only_default':True,
                            'security_containment':False,
                        },
                        actor='operator',
                        correlation_id=correlation_id,
                        mission_id=mission_id,
                    )
                    archived=bool(archive_receipt.get('verified'))
                    self.js({
                        'ok':archived,
                        'answer':answer,
                        'speaker':'ENGINEER',
                        'message':'Engineer response returned but archive verification failed.' if not archived else 'Engineer response archived.',
                        'route':'engineer',
                        'route_receipt':route_receipt,
                        'completion_receipt':completion_receipt,
                        'archive_receipt':archive_receipt,
                        'session_receipt':session_receipt,
                        'correlation_id':correlation_id,
                    })
                    return
                except Exception as e:
                    answer=f'Engineering analysis failed: {e}'
                    web_mission_session.add('SYSTEM',answer)
                    archive_receipt=web_mission_session.save()
                    self.js({
                        'ok':False,
                        'answer':answer,
                        'speaker':'SYSTEM',
                        'message':answer,
                        'route':'engineer',
                        'route_receipt':route_receipt,
                        'archive_receipt':archive_receipt,
                        'session_receipt':session_receipt,
                        'correlation_id':correlation_id,
                    })
                    return

            request_started=time.perf_counter()
            route_receipt=make_tool_receipt(
                'webui.department_route',
                'verified',
                checks=[
                    {'id':'explicit_engineer_command_absent','ok':not explicit_engineer,'message':'Ordinary chat remains with the active WebUI professor.'},
                    {'id':'agent_fox_privilege_boundary','ok':True,'message':'Agent/model text was not allowed to invoke Engineer.'},
                ],
                details={'route':'agent_fox','professor':active_prof()[0],'profile_id':chat_profile_id,'image':mission_image_receipt_details(effective_image),'image_source':context['source']},
                actor='operator',
            )

            health_started=time.perf_counter()
            chat_online=check(CHAT_HEALTH)
            health_ms=round((time.perf_counter()-health_started)*1000,1)
            if not chat_online:
                answer='Chat engine is offline. Start Chat Engine first.'
                web_mission_session.add('SYSTEM',answer)
                archive_started=time.perf_counter()
                archive_receipt=web_mission_session.save()
                archive_ms=round((time.perf_counter()-archive_started)*1000,1)
                timing={
                    'health_ms':health_ms,
                    'model_ms':0.0,
                    'guard_ms':0.0,
                    'archive_ms':archive_ms,
                    'state_save_ms':0.0,
                    'receipt_ms':0.0,
                    'server_total_ms':round((time.perf_counter()-request_started)*1000,1),
                }
                self.js({'ok':False,'answer':answer,'speaker':'SYSTEM','message':answer,'route':'agent_fox','route_receipt':route_receipt,'archive_receipt':archive_receipt,'session_receipt':session_receipt,'timing':timing})
                return

            user_message=context['history_user_message']
            request_messages=context['request_messages']
            timeline(active_project,'Image context used in Mission Console' if effective_image else 'Message sent to Mission Console') if active_project else None
            try:
                model_started=time.perf_counter()
                r=post(CHAT_API,{'model':'local-model','messages':request_messages,'temperature':0.7,'max_tokens':768,'stream':False})
                model_ms=round((time.perf_counter()-model_started)*1000,1)

                guard_started=time.perf_counter()
                raw_ans=r['choices'][0]['message']['content'].strip()
                claim_guard=guard_model_action_claims(raw_ans)
                ans=claim_guard['text']
                guard_ms=round((time.perf_counter()-guard_started)*1000,1)

                messages[:]=compact_prior_images(messages)
                messages.append(user_message)
                messages.append({'role':'assistant','content':ans})
                speaker=active_prof()[0].upper()
                web_mission_session.add(speaker,ans)

                archive_started=time.perf_counter()
                archive_receipt=web_mission_session.save()
                archive_ms=round((time.perf_counter()-archive_started)*1000,1)

                state_started=time.perf_counter()
                save_state('Agent response received')
                state_save_ms=round((time.perf_counter()-state_started)*1000,1)

                receipt_started=time.perf_counter()
                completion_receipt=make_tool_receipt(
                    'chat_completion',
                    'verified',
                    checks=[
                        {'id':'chat_api_response','ok':True,'message':'Local chat API returned a response.'},
                        {'id':'image_attachment_verified','ok':True,'message':'Image bytes and metadata were verified before model submission.' if effective_image else 'No image context was supplied.'},
                        {'id':'image_data_not_archived','ok':True,'message':'Mission Archive stores image metadata and SHA-256, never the base64 image payload.'},
                    ],
                    details={'external_action_verified':False,'claim_flagged':claim_guard['flagged'],'profile_id':chat_profile_id,'image':mission_image_receipt_details(effective_image),'image_source':context['source']},
                    actor='mission_console',
                )
                receipt_ms=round((time.perf_counter()-receipt_started)*1000,1)

                timing={
                    'health_ms':health_ms,
                    'model_ms':model_ms,
                    'guard_ms':guard_ms,
                    'archive_ms':archive_ms,
                    'state_save_ms':state_save_ms,
                    'receipt_ms':receipt_ms,
                    'server_total_ms':round((time.perf_counter()-request_started)*1000,1),
                }
                archived=bool(archive_receipt.get('verified'))
                self.js({'ok':archived,'answer':ans,'speaker':speaker,'message':'Agent response returned but archive verification failed.' if not archived else 'Agent response archived.','route':'agent_fox','claim_guard':claim_guard,'route_receipt':route_receipt,'completion_receipt':completion_receipt,'archive_receipt':archive_receipt,'session_receipt':session_receipt,'timing':timing,'active_image':context['active_image']})
                return
            except Exception as e:
                answer=f'Chat request failed: {e}'
                web_mission_session.add('SYSTEM',answer)
                archive_started=time.perf_counter()
                archive_receipt=web_mission_session.save()
                archive_ms=round((time.perf_counter()-archive_started)*1000,1)
                timing={
                    'health_ms':health_ms,
                    'model_ms':round((time.perf_counter()-model_started)*1000,1) if 'model_started' in locals() else 0.0,
                    'guard_ms':0.0,
                    'archive_ms':archive_ms,
                    'state_save_ms':0.0,
                    'receipt_ms':0.0,
                    'server_total_ms':round((time.perf_counter()-request_started)*1000,1),
                }
                self.js({'ok':False,'answer':answer,'speaker':'SYSTEM','message':answer,'route':'agent_fox','route_receipt':route_receipt,'archive_receipt':archive_receipt,'session_receipt':session_receipt,'timing':timing})
                return
        self.send_response(404); self.end_headers()
    def log_message(self,*a): return



def prompt_path(name):
    base=FOLDERS['prompts']; base.mkdir(parents=True,exist_ok=True)
    safe=slug(name or 'Untitled_Prompt')
    if safe.lower().endswith('.json'): safe=safe[:-5]
    p=(base/(safe+'.json')).resolve()
    try:
        p.relative_to(base.resolve()); return p
    except Exception:
        return None

def prompt_markdown_path(name):
    base=FOLDERS['prompts']; base.mkdir(parents=True,exist_ok=True)
    safe=slug(name or 'Untitled_Prompt')
    if safe.lower().endswith('.json'): safe=safe[:-5]
    return base/(safe+'.md')

def list_prompts():
    base=FOLDERS['prompts']; base.mkdir(parents=True,exist_ok=True)
    arr=[]
    for p in sorted(base.glob('*.json'),key=lambda x:x.stat().st_mtime,reverse=True):
        d=jread(p,{})
        body=d.get('prompt','') or d.get('body','')
        arr.append({
            'name':p.stem,
            'title':d.get('title') or p.stem,
            'notes':d.get('notes',''),
            'category':d.get('category','General'),
            'prompt_type':d.get('prompt_type','User Prompt'),
            'preview':body[:220],
            'modified':datetime.fromtimestamp(p.stat().st_mtime).strftime('%Y-%m-%d %H:%M'),
            'path':str(p)
        })
    return {'ok':True,'prompts':arr,'folder':str(base)}

def read_prompt(name):
    p=prompt_path(name)
    if not p or not p.exists():
        return {'ok':False,'message':'Prompt not found.'}
    d=jread(p,{})
    d.update({'ok':True,'name':p.stem,'path':str(p),'category':d.get('category','General'),'prompt_type':d.get('prompt_type','User Prompt')})
    return d

def save_prompt(d):
    title=(d.get('title') or 'Untitled Prompt').strip()
    prompt=(d.get('prompt') or d.get('body') or '').strip()
    notes=(d.get('notes') or '').strip()
    category=(d.get('category') or 'General').strip()
    prompt_type=(d.get('prompt_type') or d.get('type') or 'User Prompt').strip()
    if not prompt:
        return {'ok':False,'message':'Prompt body is empty.'}
    p=prompt_path(title)
    if not p:
        return {'ok':False,'message':'Invalid prompt title.'}
    old=jread(p,{}) if p.exists() else {}
    data={
        'title':title,
        'name':p.stem,
        'category':category,
        'prompt_type':prompt_type,
        'prompt':prompt,
        'notes':notes,
        'created':old.get('created',now()) if old else now(),
        'modified':now(),
        'version':'1.1',
        'source':d.get('source') or 'PromptSmith'
    }
    jwrite(p,data)
    md=prompt_markdown_path(title)
    md.write_text(f"# {title}\n\nCategory: {category}\nType: {prompt_type}\nModified: {data['modified']}\n\n## Notes\n\n{notes}\n\n## Prompt\n\n```text\n{prompt}\n```\n",encoding='utf-8')
    if active_project:
        timeline(active_project,f'PromptSmith saved prompt: {title}')
    return {'ok':True,'message':f'Saved prompt: {title}','name':p.stem,'prompt':data,'path':str(p),'markdown':str(md)}

def delete_prompt(name):
    p=prompt_path(name)
    if not p or not p.exists():
        return {'ok':False,'message':'Prompt not found.'}
    title=jread(p,{}).get('title') or p.stem
    try:
        p.unlink()
        md=prompt_markdown_path(name)
        if md.exists(): md.unlink()
    except Exception as e:
        return {'ok':False,'message':f'Delete failed: {e}'}
    if active_project:
        timeline(active_project,f'PromptSmith deleted prompt: {title}')
    return {'ok':True,'message':f'Deleted prompt: {title}'}

def duplicate_prompt(d):
    name=d.get('name','')
    p=prompt_path(name)
    if not p or not p.exists():
        return {'ok':False,'message':'Prompt not found.'}
    old=jread(p,{})
    base_title=(d.get('new_title') or (old.get('title') or p.stem)+' Copy').strip()
    new_data=dict(old)
    new_data['title']=base_title
    new_data['source']='PromptSmith Duplicate'
    return save_prompt(new_data)

def rename_prompt(d):
    name=d.get('name','')
    new_title=(d.get('new_title') or '').strip()
    if not new_title:
        return {'ok':False,'message':'New title is required.'}
    p=prompt_path(name)
    if not p or not p.exists():
        return {'ok':False,'message':'Prompt not found.'}
    data=jread(p,{})
    old_title=data.get('title') or p.stem
    data['title']=new_title
    result=save_prompt(data)
    if result.get('ok'):
        try:
            p.unlink()
            old_md=prompt_markdown_path(name)
            if old_md.exists(): old_md.unlink()
        except Exception:
            pass
        if active_project:
            timeline(active_project,f'PromptSmith renamed prompt: {old_title} -> {new_title}')
    return result


def novel_root():
    p=FOLDERS.get('novel_forge',ROOT/'NovelForge')
    p.mkdir(parents=True,exist_ok=True)
    return p

def novel_path(name):
    base=novel_root()
    safe=slug(name or 'Untitled_Universe')
    if safe.lower().endswith('.json'): safe=safe[:-5]
    p=(base/(safe+'.json')).resolve()
    try:
        p.relative_to(base.resolve()); return p
    except Exception:
        return None

def novel_md_path(name):
    base=novel_root()/'Markdown'
    base.mkdir(parents=True,exist_ok=True)
    safe=slug(name or 'Untitled_Universe')
    return base/(safe+'.md')

def list_universes():
    base=novel_root()
    arr=[]
    for p in sorted(base.glob('*.json'),key=lambda x:x.stat().st_mtime,reverse=True):
        d=jread(p,{})
        arr.append({
            'name':p.stem,
            'universe':d.get('universe') or d.get('name') or p.stem,
            'premise':(d.get('premise') or '')[:220],
            'characters':len(d.get('characters',[])) if isinstance(d.get('characters'),list) else 0,
            'locations':len(d.get('locations',[])) if isinstance(d.get('locations'),list) else 0,
            'artifacts':len(d.get('artifacts',[])) if isinstance(d.get('artifacts'),list) else 0,
            'timeline':len(d.get('timeline',[])) if isinstance(d.get('timeline'),list) else 0,
            'mysteries':len(d.get('mysteries',[])) if isinstance(d.get('mysteries'),list) else 0,
            'scenes':len(d.get('scenes',[])) if isinstance(d.get('scenes'),list) else 0,
            'modified':datetime.fromtimestamp(p.stat().st_mtime).strftime('%Y-%m-%d %H:%M')
        })
    return {'ok':True,'universes':arr,'folder':str(base)}

def read_universe(name):
    p=novel_path(name)
    if not p or not p.exists():
        return {'ok':False,'message':'Universe not found.'}
    d=jread(p,{})
    d.update({'ok':True,'file_name':p.stem,'path':str(p)})
    return d

def lines_to_list(value):
    if isinstance(value,list):
        return [str(x).strip() for x in value if str(x).strip()]
    return [x.strip() for x in str(value or '').splitlines() if x.strip()]

def save_universe(d):
    name=(d.get('universe') or d.get('name') or 'Untitled Universe').strip()
    if not name:
        return {'ok':False,'message':'Universe name is required.'}
    p=novel_path(name)
    if not p:
        return {'ok':False,'message':'Invalid universe name.'}
    old=jread(p,{}) if p.exists() else {}
    data={
        'universe':name,
        'file_name':p.stem,
        'premise':(d.get('premise') or '').strip(),
        'characters':lines_to_list(d.get('characters','')),
        'locations':lines_to_list(d.get('locations','')),
        'artifacts':lines_to_list(d.get('artifacts','')),
        'timeline':lines_to_list(d.get('timeline','')),
        'mysteries':lines_to_list(d.get('mysteries','')),
        'scenes':lines_to_list(d.get('scenes','')),
        'notes':(d.get('notes') or '').strip(),
        'created':old.get('created',now()) if old else now(),
        'modified':now(),
        'version':'0.1',
        'source':'Novel Forge'
    }
    jwrite(p,data)
    md=novel_md_path(name)
    md.write_text(
        f"# {name}\n\n"
        f"Modified: {data['modified']}\n\n"
        f"## Premise\n\n{data['premise']}\n\n"
        f"## Characters\n\n" + "\n".join(f"- {x}" for x in data['characters']) + "\n\n"
        f"## Locations\n\n" + "\n".join(f"- {x}" for x in data['locations']) + "\n\n"
        f"## Artifacts\n\n" + "\n".join(f"- {x}" for x in data['artifacts']) + "\n\n"
        f"## Timeline\n\n" + "\n".join(f"- {x}" for x in data['timeline']) + "\n\n"
        f"## Mysteries / Unresolved Threads\n\n" + "\n".join(f"- {x}" for x in data['mysteries']) + "\n\n"
        f"## Scenes\n\n" + "\n".join(f"- {x}" for x in data.get('scenes',[])) + "\n\n"
        f"## Notes\n\n{data['notes']}\n",
        encoding='utf-8'
    )
    if active_project:
        timeline(active_project,f'Novel Forge saved universe: {name}')
    return {'ok':True,'message':f'Saved universe: {name}','universe':data,'name':p.stem,'path':str(p),'markdown':str(md)}

def duplicate_universe(d):
    name=d.get('name','')
    new_title=(d.get('new_title') or '').strip()
    p=novel_path(name)
    if not p or not p.exists():
        return {'ok':False,'message':'Universe not found.'}
    old=jread(p,{})
    if not new_title:
        new_title=(old.get('universe') or p.stem)+' Copy'
    old['universe']=new_title
    old['source']='Novel Forge Duplicate'
    return save_universe(old)

def rename_universe(d):
    name=d.get('name','')
    new_title=(d.get('new_title') or '').strip()
    if not new_title:
        return {'ok':False,'message':'New universe name is required.'}
    p=novel_path(name)
    if not p or not p.exists():
        return {'ok':False,'message':'Universe not found.'}
    old=jread(p,{})
    old_title=old.get('universe') or p.stem
    old['universe']=new_title
    result=save_universe(old)
    if result.get('ok'):
        try:
            p.unlink()
            md=novel_md_path(name)
            if md.exists(): md.unlink()
        except Exception:
            pass
        if active_project:
            timeline(active_project,f'Novel Forge renamed universe: {old_title} -> {new_title}')
    return result

def delete_universe(name):
    p=novel_path(name)
