class _WebEngineerApp:
    """Minimal adapter for Engineer's existing read-only analysis surface."""
    models=[]
    threads=8

WEB_ENGINEER_WRITE_COMMANDS=(
    'chisel decision for ',
    'log decision for ',
    'record decision for ',
    'log lesson for ',
    'chisel lesson for ',
    'log forge for ',
    'forge journal entry for ',
)

def web_engineer_read_only_allowed(text):
    normalized=re.sub(r'^\s*(?:/engineer\b|engineer\s*[:,])\s*','',text or '',flags=re.IGNORECASE).strip().lower()
    return not any(normalized.startswith(marker) for marker in WEB_ENGINEER_WRITE_COMMANDS)

def web_mission_context():
    return {
        'project':active_project or 'Default_Mission',
        'professor':active_prof()[0],
        'model':Path(chat_model).name if chat_model else 'None',
    }

def begin_web_mission_session():
    return web_mission_session.start(**web_mission_context())

def ensure_web_mission_session():
    return web_mission_session.ensure_started(**web_mission_context())

def web_engineer_analyze(
    text,
    *,
    mission_id='',
    correlation_id='',
    route_audit_receipt=None,
    inspect_authorization=None,
    inspect_audit_receipt=None,
    caller='operator',
):
    # Explicit owner-use Engineer route. Legacy keywords remain accepted.
    _ = (
        mission_id,
        correlation_id,
        route_audit_receipt,
        inspect_authorization,
        inspect_audit_receipt,
        caller,
    )
    global _web_engineer

    with _web_engineer_lock:
        if _web_engineer is None:
            from core.engineer_agent import EngineerAgent
            _web_engineer=EngineerAgent(_WebEngineerApp())

        return _web_engineer.analyze(text)


