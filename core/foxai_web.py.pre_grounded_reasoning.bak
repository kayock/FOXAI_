    go('mission');
    q('input').value=`Please review this Kayock Repair Shop Session Report.

Health:
${d.health_label}

Summary:
Repair Shop health: ${s.repair_shop_health}
Ticket Queue health: ${s.ticket_queue_health}
Verified Action health: ${s.verified_action_health}
