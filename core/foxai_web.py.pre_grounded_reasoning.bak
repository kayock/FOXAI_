def log(s): LOGS.mkdir(exist_ok=True); LOG.open('a',encoding='utf-8').write(f"[{datetime.now():%F %T}] {s}\n")
def now(): return datetime.now().isoformat(timespec='seconds')
def jread(p,d):
    try: return json.loads(p.read_text(encoding='utf-8')) if p.exists() else d
    except Exception: return d
def jwrite(p,d): p.parent.mkdir(parents=True,exist_ok=True); p.write_text(json.dumps(d,indent=2),encoding='utf-8')
def slug(n): return (re.sub(r'[^A-Za-z0-9 _.-]','',n).strip().replace(' ','_')[:80] or 'New_Project')
def ppath(name):
    c=(PROJECTS/slug(name)).resolve()
    try: c.relative_to(PROJECTS.resolve()); return c
    except Exception: return None
def active_prof(): return PROF.get(prof,PROF['fox'])
def reset_msgs():
    global messages
    messages=[{'role':'system','content':professor_system_prompt(prof)}]
    clear_active_mission_image()
def timeline(project,event):
    p=ppath(project); 
    if not p: return
    arr=jread(p/'timeline.json',[]); arr.append({'time':now(),'event':event}); jwrite(p/'timeline.json',arr[-500:])
def ensure_mission(project):
    p=ppath(project); p.mkdir(parents=True,exist_ok=True)
    m=jread(p/'mission.json',None)
    if not m:
        m={'project':p.name,'created':now(),'last_opened':now(),'active_professor':prof,'active_professor_name':active_prof()[0],'active_model':chat_model,'active_model_name':Path(chat_model).name if chat_model else None,'current_task':'Getting started','notes_file':'FOXAI_PROJECT_NOTES.md'}
        jwrite(p/'mission.json',m); timeline(p.name,'Mission memory initialized')
    return m
def save_state(event=None):
    if not active_project: return {'ok':False,'message':'No active project selected.'}
    p=ppath(active_project); m=ensure_mission(active_project)
    m.update({'last_opened':now(),'active_professor':prof,'active_professor_name':active_prof()[0],'active_model':chat_model,'active_model_name':Path(chat_model).name if chat_model else None})
    jwrite(p/'mission.json',m)
    if event: timeline(active_project,event)
    return {'ok':True,'message':'Mission state saved.','mission':m}
def tasks(): return jread(ppath(active_project)/'tasks.json',[]) if active_project else []
def save_tasks(t): jwrite(ppath(active_project)/'tasks.json',t)
def models():
    bases=[ROOT/'Models'/'Chat',ROOT/'Models',ROOT/'models',ROOT/'Engine']; out=[]; seen=set()
    for b in bases:
        if b.exists():
            for p in b.rglob('*.gguf'):
                lowered=p.name.casefold()
                if 'mmproj' in lowered or 'projector' in lowered:
                    continue
                k=str(p.resolve()).lower()
                if k not in seen: seen.add(k); out.append(p)
    return sorted(out,key=lambda p:p.name.lower())


def model_source_catalog():
    try:
        return model_source_registry.catalog()
    except ModelSourceError:
        return []


def model_source_state(include_catalog=True):
    try:
        return model_source_registry.state(include_catalog=bool(include_catalog))
    except ModelSourceError as exc:
        return {'ok':False,'message':str(exc),'models':[],'counts':{'total':0,'usb':0,'host_pc':0}}


def model_source_choose_folder():
    result=choose_host_model_folder()
    result['model_files_modified']=False
    result['registry_modified']=False
    return result


def model_source_approve_folder(data):
    try:
        remember=str(data.get('scope') or '').strip().lower()=='remembered'
        result=model_source_registry.approve_folder(
            data.get('path',''),
            remember=remember,
            confirm=bool(data.get('confirm')),
        )
    except ModelSourceError as exc:
        return {'ok':False,'message':str(exc),'model_files_modified':False,'registry_modified':False}
    result['registry_modified']=bool(remember)
    result['receipt']=make_tool_receipt(
        'model_sources.approve_folder',
        'verified',
        checks=[
            {'id':'explicit_confirmation','ok':True,'message':'Operator confirmed the folder approval.'},
            {'id':'specific_folder_only','ok':True,'message':'Whole-drive scanning remained prohibited.'},
            {'id':'model_files_unchanged','ok':True,'message':'No model file was modified.'},
        ],
        details={'path':result.get('path'),'scope':result.get('scope'),'model_count':result.get('model_count',0)},
        actor='operator',
    )
    return result


def model_source_forget_folder(data):
    try:
        result=model_source_registry.forget_folder(
            data.get('path',''),
            confirm=bool(data.get('confirm')),
        )
    except ModelSourceError as exc:
        return {'ok':False,'message':str(exc),'model_files_modified':False}
    if result.get('ok'):
        result['receipt']=make_tool_receipt(
            'model_sources.forget_folder',
            'verified',
            checks=[{'id':'reference_only','ok':True,'message':'Only FOXAI registry references were removed.'}],
            details={'path':result.get('path'),'model_files_modified':False},
            actor='operator',
        )
    return result


def model_source_forget_model(data):
    try:
        result=model_source_registry.forget_model(
            data.get('path',''),
            confirm=bool(data.get('confirm')),
        )
    except ModelSourceError as exc:
        return {'ok':False,'message':str(exc),'model_files_modified':False}
    if result.get('ok'):
        result['receipt']=make_tool_receipt(
            'model_sources.forget_model',
            'verified',
            checks=[{'id':'preference_only','ok':True,'message':'Only the preferred-model reference was removed.'}],
            details={'path':result.get('path'),'model_files_modified':False},
            actor='operator',
        )
    return result


def model_source_forget_machine(data):
    try:
        result=model_source_registry.forget_machine(confirm=bool(data.get('confirm')))
    except ModelSourceError as exc:
        return {'ok':False,'message':str(exc),'model_files_modified':False}
    if result.get('ok'):
        result['receipt']=make_tool_receipt(
            'model_sources.forget_machine',
            'verified',
            checks=[{'id':'profile_reference_only','ok':True,'message':'Only the current machine profile and session references were removed.'}],
            details={'machine_name':result.get('machine_name'),'model_files_modified':False},
            actor='operator',
        )
    return result
def check(url):
    try:
        import urllib.request; urllib.request.urlopen(url,timeout=1.5).read(32); return True
    except Exception: return False
def post(url,payload,timeout=300):
    import urllib.request
    req=urllib.request.Request(url,data=json.dumps(payload).encode(),headers={'Content-Type':'application/json'})
    with urllib.request.urlopen(req,timeout=timeout) as r: return json.loads(r.read().decode(errors='replace'))

# KAYOCKS_STUDY_INTEGRATION_V1_HELPERS_START
def _bibliotheca_json(route,timeout=2.0):
    import urllib.request
    with urllib.request.urlopen(BIBLIOTHECA_URL+route,timeout=timeout) as response:
        return json.loads(response.read().decode('utf-8',errors='replace'))

def _bibliotheca_database_state():
    empty={'documents':0,'pages':0,'searchable':0,'low_text':0,'ocr_copies':0,'shelves':0,'duplicate_groups':0,'text_chars':0,'research_saved':0}
    if not BIBLIOTHECA_DATABASE.is_file():
        return empty,[]
    import sqlite3
    connection=None
    try:
        uri=BIBLIOTHECA_DATABASE.resolve().as_uri()+'?mode=ro'
        connection=sqlite3.connect(uri,uri=True,timeout=4)
        connection.row_factory=sqlite3.Row
        row=connection.execute("""
            SELECT COUNT(*) documents,COALESCE(SUM(page_count),0) pages,
            COALESCE(SUM(text_chars),0) text_chars,
            SUM(CASE WHEN text_status IN ('searchable','searchable_ocr_copy','partially_searchable') THEN 1 ELSE 0 END) searchable,
            SUM(CASE WHEN text_status='image_only_or_low_text' THEN 1 ELSE 0 END) low_text,
            SUM(is_ocr_copy) ocr_copies FROM documents
        """).fetchone()
        shelf_rows=connection.execute("""
            SELECT CASE WHEN INSTR(rel_path,'/')>0 THEN SUBSTR(rel_path,1,INSTR(rel_path,'/')-1) ELSE 'Library' END shelf,
            COUNT(*) documents,COALESCE(SUM(page_count),0) pages
            FROM documents GROUP BY shelf ORDER BY shelf COLLATE NOCASE
        """).fetchall()
        duplicate_groups=connection.execute("""
            SELECT COUNT(*) FROM (
              SELECT sha256 FROM documents WHERE COALESCE(sha256,'')<>'' GROUP BY sha256 HAVING COUNT(*)>1
            )
        """).fetchone()[0]
        shelves=[{'name':str(x['shelf'] or 'Library'),'documents':int(x['documents'] or 0),'pages':int(x['pages'] or 0)} for x in shelf_rows]
        research_saved=0
        try:
            research_saved=int(connection.execute("SELECT COUNT(*) FROM research_captures").fetchone()[0])
        except Exception:
            research_saved=0
        summary={'documents':int(row['documents'] or 0),'pages':int(row['pages'] or 0),'searchable':int(row['searchable'] or 0),'low_text':int(row['low_text'] or 0),'ocr_copies':int(row['ocr_copies'] or 0),'shelves':len(shelves)+(1 if research_saved else 0),'duplicate_groups':int(duplicate_groups or 0),'text_chars':int(row['text_chars'] or 0),'research_saved':research_saved}
        return summary,shelves
    except Exception:
        return empty,[]
    finally:
        if connection is not None:
            connection.close()

def bibliotheca_status():
    installed=BIBLIOTHECA_SERVER.is_file()
    summary,shelves=_bibliotheca_database_state()
    result={'ok':True,'installed':installed,'online':False,'url':BIBLIOTHECA_URL,'version':'','model_online':False,'model_name':'','indexing':False,'summary':summary,'shelves':shelves,'message':"Kayock's Study is ready to start." if installed else "Kayock's Study files were not found.",'database':str(BIBLIOTHECA_DATABASE),'database_preserved':True,'network_scope':'localhost_only'}
    if not installed:
        return result
    try:
        status=_bibliotheca_json('/api/status',1.5)
        shelf_data=_bibliotheca_json('/api/shelves',2.0)
        result.update({'online':bool(status.get('ok')),'version':str(status.get('version') or ''),'model_online':bool(status.get('model_online')),'model_name':str(status.get('model_name') or ''),'indexing':bool((status.get('state') or {}).get('indexing')),'summary':status.get('summary') or summary,'shelves':shelf_data.get('shelves') or shelves,'message':"Kayock's Study and The Bibliotheca are online."})
    except Exception:
        pass
    return result

def start_bibliotheca():
    global bibliotheca_process
    current=bibliotheca_status()
    if current.get('online'):
        current.update({'message':"Kayock's Study is already online.",'started_now':False})
        return current
    portable=ROOT/'Runtime'/'Desktop'/'python'/'python.exe'
    checks=[
        {'id':'bibliotheca_server_present','ok':BIBLIOTHECA_SERVER.is_file(),'message':str(BIBLIOTHECA_SERVER)},
        {'id':'portable_python_present','ok':portable.is_file(),'message':str(portable)},
        {'id':'library_present','ok':LIB.is_dir(),'message':str(LIB)},
    ]
    if not all(item['ok'] for item in checks):
        return {**current,'ok':False,'message':"Kayock's Study could not start because a required file is missing.",'receipt':make_tool_receipt('kayocks_study.start','blocked',checks=checks,details={'database_modified':False,'original_pdfs_modified':False},actor='operator')}
    env=os.environ.copy()
    for key in ('PYTHONHOME','PYTHONPATH'): env.pop(key,None)
    env['PYTHONNOUSERSITE']='1';env['PYTHONDONTWRITEBYTECODE']='1'
    command=[str(portable),'-I','-B','-S',str(BIBLIOTHECA_SERVER),'--root',str(ROOT),'--port','8777']
    try:
        bibliotheca_process=subprocess.Popen(command,cwd=str(BIBLIOTHECA_DIR),env=env,creationflags=subprocess.CREATE_NEW_CONSOLE if os.name=='nt' else 0)
    except Exception as exc:
        return {**current,'ok':False,'message':f"Kayock's Study launch failed: {type(exc).__name__}: {exc}",'receipt':make_tool_receipt('kayocks_study.start','blocked',checks=checks+[{'id':'process_spawn','ok':False,'message':str(exc)}],details={'database_modified':False,'original_pdfs_modified':False},actor='operator')}
    deadline=time.time()+15
    verified=current
    while time.time()<deadline:
        time.sleep(.35)
        verified=bibliotheca_status()
        if verified.get('online'): break
    online=bool(verified.get('online'))
    verified.update({'ok':online,'started_now':True,'message':"Kayock's Study is online." if online else "Kayock's Study was launched but is still starting.",'receipt':make_tool_receipt('kayocks_study.start','verified' if online else 'requested',checks=checks+[{'id':'localhost_health','ok':online,'message':'The Bibliotheca answered on 127.0.0.1:8777.' if online else 'The process launched; health is not verified yet.'}],details={'url':BIBLIOTHECA_URL,'pid':getattr(bibliotheca_process,'pid',None),'database_modified':False,'original_pdfs_modified':False,'network_scope':'localhost_only'},actor='operator')})
    return verified
